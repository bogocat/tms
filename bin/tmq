#!/usr/bin/env bash
# tmq — tmux agent queue: spawn a coding agent on a GitHub issue
#
# Usage:
#   tmq <repo> <issue-number> [--agent cc|pi|oc] [--type feature|fix|chore|review]
#   tmq list                          list known repos
#   tmq review <repo> <pr-number>     spawn a code review agent on a PR
#
# Examples:
#   tmq distillery 245                  # pi on distillery#245 (default agent)
#   tmq home-portal 57 --agent cc      # claude on home-portal#57
#   tmq tower-fleet 78 --type review   # PR review on tower-fleet#78
#   tmq scripts 5 --type fix           # bugfix on bogocat/scripts#5
#
# For feature work on repos that need worktrees (distillery, home-portal,
# scripts), tmq automatically creates a git worktree. For fixes/chores on
# main, it uses the main checkout directly.

set -euo pipefail

# ── repo registry ────────────────────────────────────────────────
# Format: short_name:local_path:github_repo:needs_worktree

declare -A REPO_PATH REPO_GH REPO_WORKTREE

add_repo() {
    local name=$1 path=$2 gh=$3 wt=${4:-0}
    REPO_PATH[$name]="$path"
    REPO_GH[$name]="$gh"
    REPO_WORKTREE[$name]="$wt"
}

add_repo distillery   /root/projects/distillery    bogocat/distillery    1
add_repo home-portal  /root/projects/home-portal   bogocat/home-portal   1
add_repo tower-fleet  /root/tower-fleet            bogocat/tower-fleet   1
add_repo scripts      /root/scripts                bogocat/scripts       1
add_repo palimpsest   /root/projects/palimpsest    bogocat/palimpsest    0
add_repo rms          /root/projects/rms           bogocat/openrms       0
add_repo deploy       /root/deploy/distillery      bogocat/distillery    0
add_repo frame-cache  /root/projects/framecache    bogocat/framecache    0
add_repo tms          /root/tms                    bogocat/tms           1

# Active bogocat app/tool repos. worktree=0 per the rms/palimpsest convention
# (only cron-read / CI-deploy / concurrent-clobber repos above are 1). Flip a
# repo to 1 if it starts getting concurrent feature work on its main checkout.
add_repo timesheet           /root/projects/timesheet           bogocat/timesheet           0
add_repo jellyfin-3ds        /root/projects/jellyfin-3ds        bogocat/jellyfin-3ds        0
add_repo quantumera-tactics  /root/projects/quantumera-tactics  bogocat/quantumera-tactics  0
add_repo subtitleai          /root/projects/subtitleai          bogocat/subtitlesv2         0
add_repo tcg                 /root/projects/tcg                 bogocat/tcg                 0
add_repo trip-planner        /root/projects/trip-planner        bogocat/trip-planner        0
add_repo music-control       /root/projects/music-control       bogocat/music-control       0
add_repo music-display       /root/projects/music-display       bogocat/music-display       0
add_repo garden              /root/projects/garden              bogocat/garden              0
# worktree=1: hostd (garmin-doctor-hostd.service) imports from this live tree, so
# in-place branch switches would risk the running Max-sub bridge. See deploy/hostd.md.
add_repo garmin-doctor       /root/projects/garmin-doctor       bogocat/garmin-doctor       1
# worktree=1: LIVE skill tree -- ~/.claude/skills and ~/.pi/agent/skills symlink into
# this repo, so an in-place branch switch instantly changes live skill content for
# every running agent. Always isolate in a worktree.
add_repo pi-dotfiles         /root/pi-dotfiles                  bogocat/pi-dotfiles         1
# worktree=1: active foreman development; daemon runs from the uv-installed
# package (not this tree), but main gets concurrent feature work (22 PRs 07-16).
add_repo openagent           /root/projects/openagent           bogocat/openagent           1

# ── defaults ─────────────────────────────────────────────────────

DEFAULT_AGENT="pi"
PI_PROVIDER=""          # forwarded to pi --provider (empty = pi default)
PI_MODEL=""             # forwarded to pi --model   (empty = pi default)
ISSUE_TYPE="feature"   # feature | fix | chore | review

# ── help ─────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
tmq — spawn a coding agent on a GitHub issue

Usage:
  tmq <repo> <issue> [--agent cc|pi|oc] [--type feature|fix|chore|review]
                     [--provider <name>] [--model <id>]
  tmq list
  tmq review <repo> <pr-number> [--agent cc|pi|oc]

Examples:
  tmq distillery 245 --agent pi --model MiniMax-M3   # pi on a specific model
  tmq home-portal 57 --agent cc                      # claude (auto)

Repos:
  distillery    home-portal   tower-fleet   scripts
  palimpsest    rms           deploy        frame-cache

Agents:
  pi    Pi Coding Agent (default, auto mode)
  cc    Claude Code (auto mode)
  oc    Opencode

Model flags (pi only — forwarded to pi's --provider/--model):
  --provider <name>   Override pi's provider (e.g. minimax)
  --model <id>        Override pi's model    (e.g. MiniMax-M3)
  Using --provider/--model with --agent cc or oc is an error (cc model
  selection is out of band; oc has no model flag). pi validates the id.

Root note (cc): Claude Code refuses --dangerously-skip-permissions under
  root/sudo, so `--agent cc` fails fast on a root host. To spawn an
  autonomous root cc agent anyway (no permission guardrails — deliberate
  security tradeoff, tms#39), opt in explicitly:
    TMQ_ALLOW_ROOT_CC=1 tmq <repo> <issue> --agent cc

Types:
  feature   new feature branch + worktree (default)
  fix       bugfix, typically on main
  chore     maintenance, on main
  review    PR code review (use 'tmq review' shorthand)

EOF
    exit 0
}

list_repos() {
    printf "%-15s %-45s %s\n" "REPO" "PATH" "WORKTREE?"
    printf "%s\n" "──────────────────────────────────────────────────────────────"
    for name in "${!REPO_PATH[@]}"; do
        local wt="no"
        (( REPO_WORKTREE[$name] == 1 )) && wt="yes"
        printf "%-15s %-45s %s\n" "$name" "${REPO_PATH[$name]}" "$wt"
    done
}

# Machine-readable registry. Tab-separated, one repo per line.
# Fields: short<TAB>local_path<TAB>gh_repo<TAB>needs_worktree
# Used by `tms` to derive its own repo awareness from the canonical registry.
list_repos_machine() {
    for name in "${!REPO_PATH[@]}"; do
        printf "%s\t%s\t%s\t%s\n" \
            "$name" "${REPO_PATH[$name]}" "${REPO_GH[$name]}" "${REPO_WORKTREE[$name]}"
    done
}

# ── helpers ──────────────────────────────────────────────────────

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

next_scratch_name() {
    local prefix=$1
    local max=-1
    while IFS= read -r name; do
        [[ "$name" =~ ^${prefix}([0-9]+)$ ]] || continue
        local n=${BASH_REMATCH[1]}
        (( n > max )) && max=$n
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null)"
    echo "${prefix}$((max + 1))"
}

# ── issue fetching ───────────────────────────────────────────────

fetch_issue() {
    local repo=$1 number=$2
    local gh_repo="${REPO_GH[$repo]}"

    gh issue view "$number" --repo "$gh_repo" --json title,body,labels,state,url 2>/dev/null \
        || { echo "ERROR: Could not fetch $gh_repo#$number"; exit 1; }
}

fetch_pr() {
    local repo=$1 number=$2
    local gh_repo="${REPO_GH[$repo]}"

    # Non-fatal: returns empty on failure so the caller can fall back
    # to issue→PR lookup (#10, item 4).
    gh pr view "$number" --repo "$gh_repo" --json title,body,state,url,additions,deletions,files 2>/dev/null
}

# Resolve a number that may be a PR or an issue to a PR number.
# Item 4 (#10): `tmq review` should accept issue numbers, not just PR
# numbers. Tries gh pr view first; on miss, looks up linked PRs via
# `gh pr list --search "issue:<num>"` (open first, then merged).
# Echoes the resolved PR number on success, returns non-zero on failure.
resolve_pr_number() {
    local repo=$1 number=$2
    local gh_repo="${REPO_GH[$repo]}"

    # Try as PR number first (use --json number,title — single-field
    # --json number succeeds even for issues in gh 2.46.0; multi-field
    # triggers GraphQL validation and correctly fails for non-PRs)
    if gh pr view "$number" --repo "$gh_repo" --json number,title &>/dev/null; then
        echo "$number"
        return 0
    fi

    # Try as issue number: look up open linked PRs
    local pr_num
    pr_num=$(gh pr list --repo "$gh_repo" --state open --search "issue:$number" \
        --json number --jq '.[0].number' 2>/dev/null) || pr_num=""
    if [[ -n "$pr_num" ]]; then
        echo "$pr_num"
        return 0
    fi

    # Try merged PRs if no open ones
    pr_num=$(gh pr list --repo "$gh_repo" --state merged --search "issue:$number" \
        --json number --jq '.[0].number' 2>/dev/null) || pr_num=""
    if [[ -n "$pr_num" ]]; then
        echo "$pr_num"
        return 0
    fi

    return 1
}

# ── prompt construction ──────────────────────────────────────────

build_prompt() {
    local repo=$1 number=$2 type=$3 agent=${4:-pi}

    if [[ "$type" == "review" ]]; then
        # Item 4 (#10): use the resolved PR number from main()
        # (stored in TMQ_REVIEW_PR_NUM) rather than calling
        # resolve_pr_number again — avoids a duplicate gh API call
        # (#10 review, P1).
        local pr_json
        pr_json=$(fetch_pr "$repo" "$TMQ_REVIEW_PR_NUM")
        local title url state adds dels
        title=$(echo "$pr_json" | jq -r '.title')
        url=$(echo "$pr_json" | jq -r '.url')
        state=$(echo "$pr_json" | jq -r '.state')
        adds=$(echo "$pr_json" | jq -r '.additions')
        dels=$(echo "$pr_json" | jq -r '.deletions')
        local body
        body=$(echo "$pr_json" | jq -r '.body')

        # Branch info: gate on TMQ_REUSED (set only when create_worktree
        # actually reused a feat session's worktree), not TMQ_BRANCH —
        # detached HEAD leaves TMQ_BRANCH empty even though we DID reuse,
        # and that would make the prompt mis-report.
        local branch_section pull_step fixup_step
        if [[ "$TMQ_REUSED" -eq 1 ]]; then
            local live_note=""
            if [[ "$TMQ_FEAT_LIVE" -ne 1 ]]; then
                live_note=" (note: feat session is not currently running)"
            fi
            branch_section="**Worktree:** $TMQ_CWD (shared with the feature agent${live_note})
**Branch:** ${TMQ_BRANCH:-<detached>}"
            pull_step="You are in a git worktree shared with the feature
   agent. Pull the latest branch state before reviewing:
   \`git -C \"$TMQ_CWD\" pull --ff-only\`
   If that fails because the feat agent has un-pushed local commits,
   skip the pull — your local view of the branch is already ahead
   of origin. If it fails for a different reason, report the failure
   to the user before proceeding."
            fixup_step="Shared-worktree case: push fixups to the same
   branch so the feat agent sees them on their next read."
        else
            branch_section="**Worktree:** $TMQ_CWD (main checkout — no feat session to reuse)"
            pull_step="Check out the PR branch and review the diff."
            fixup_step="Main-checkout case: do not push to the PR branch
   directly — the PR branch is owned by whoever opened it. Surface
   review findings for the human to apply."
        fi

        cat <<PROMPT
## Code Review: ${REPO_GH[$repo]}#$number

**PR:** $title
**URL:** $url
**State:** $state (+$adds -$dels)
$branch_section

### PR Description
$body

### Review Instructions
1. $pull_step
2. Evaluate: correctness, architecture, security, performance, test coverage
3. Classify issues as P0 (must fix), P1 (should fix), P2 (nice to have)
4. Focus on logic errors and design flaws over style nits
5. Output a structured review: Summary / P0 Issues / P1 Issues / P2 Notes / Overall
6. $fixup_step
PROMPT
    else
        local issue_json
        issue_json=$(fetch_issue "$repo" "$number")
        local title url state labels
        title=$(echo "$issue_json" | jq -r '.title')
        url=$(echo "$issue_json" | jq -r '.url')
        state=$(echo "$issue_json" | jq -r '.state')
        labels=$(echo "$issue_json" | jq -r '.labels[].name' 2>/dev/null | tr '\n' ' ')
        local body
        body=$(echo "$issue_json" | jq -r '.body')

        local type_instruction lifecycle_instruction
        case "$type" in
            feature)
                type_instruction="3. **Implement this feature.** You are in a git worktree on branch
   \`$TMQ_BRANCH\`. Commit incrementally. When the implementation is complete:
   - Open a PR against main
   - Report the PR number and URL
   - **Do NOT delete or remove the worktree.** Your session stays alive —
     code review will follow in this same session (reviewer may push fixups).
   - Only after the PR is merged should you clean up."
                lifecycle_instruction="4. **Lifecycle:** Open PR → wait for review → apply feedback → merge → cleanup.
   Do not treat the PR as the finish line."
                ;;
            fix)
                type_instruction="3. **Fix this bug.** Work on main (or a short-lived fix branch). Commit the fix."
                lifecycle_instruction=""
                ;;
            chore)
                type_instruction="3. **Complete this maintenance task.** Work directly on main."
                lifecycle_instruction=""
                ;;
        esac

        # Loop discipline pointer (#20, #38). pi loads its dispatch-loop skill;
        # cc now has a Claude-native dispatch-loop skill (#38) — prefer it when
        # installed so the loop travels with every cc dispatch even in a repo
        # with no AGENTS.md. Fall back to the repo's AGENTS.md, then to nothing.
        # oc (opencode) has no skill, so it keeps the AGENTS.md fallback only.
        local agents_md_ptr=""
        if [[ -f "${TMQ_CWD}/AGENTS.md" ]]; then
            agents_md_ptr="**Read and follow \`AGENTS.md\`** in the repo root — the in-session loop: \`<<AGENT-STATE: ...>>\` markers + plan-gate / TDD-first / AC-verify."
        fi
        local loop_instruction=""
        case "$agent" in
            pi)
                loop_instruction="**Follow the \`dispatch-loop\` skill.** Print \`<<AGENT-STATE: ...>>\` on its own line at every transition, and run the loop: plan-gate (STOP at PLAN-REVIEW for human approval before writing code) -> TDD-first -> AC-verify before opening the PR. For large/sensitive plans call \`proposal-review\` at the plan gate; \`code-review\` runs at PR-REVIEW."
                ;;
            cc)
                if [[ -f "${HOME}/.claude/skills/dispatch-loop/SKILL.md" ]]; then
                    loop_instruction="**Follow the \`dispatch-loop\` skill.** Print \`<<AGENT-STATE: ...>>\` on its own line at every transition, and run the loop: plan-gate (STOP at PLAN-REVIEW for human approval before writing code) -> TDD-first -> AC-verify before opening the PR. \`/code-review\` runs at PR-REVIEW."
                else
                    loop_instruction="$agents_md_ptr"
                fi
                ;;
            oc)
                loop_instruction="$agents_md_ptr"
                ;;
        esac

        cat <<PROMPT
## $type: ${REPO_GH[$repo]}#$number

**Title:** $title
**URL:** $url
**State:** $state
**Labels:** $labels

### Issue Description
$body

### Instructions
$loop_instruction

1. **Evaluate scope against ground truth first.** Don't trust the issue's task
   list at face value — issues rot. Check:
   - What has already been done? (grep for patterns the issue mentions; scan
     git log for related commits)
   - What data actually exists? (query the database to verify assumptions the
     issue makes about tables, columns, or content)
   - What's the real delta? (diff between the issue's desired end-state and
     the current state of the codebase)
2. **Refine the scope**, report discrepancies, then proceed with the actual
   remaining work.
$type_instruction
$lifecycle_instruction

Repository: $repo (${REPO_PATH[$repo]})
Worktree:  $TMQ_CWD (branch: $TMQ_BRANCH)
Follow the project conventions in CLAUDE.md and institutional memory.
PROMPT
    fi
}

# ── session spawn ────────────────────────────────────────────────

# Returns 0 (true) iff opt-in auto-attach is requested via TMS_TMQ_LAUNCH=1.
# Only the literal "1" opts in — empty/garbage/common-truthy stay out so env
# noise can't accidentally drop the user into an agent session. Default
# (unset) is dispatch-then-return. Extracted to its own function so the
# pytest suite can source the script and exercise it directly. (tms#12)
_tmq_want_auto_attach() {
    [[ "${TMS_TMQ_LAUNCH:-}" == "1" ]]
}

spawn_agent() {
    local session_name=$1 cwd=$2 prompt=$3 agent=$4 branch=$5
    local dispatch_repo=${6:-} dispatch_issue=${7:-} dispatch_type=${8:-}
    local dispatch_provider=${9:-} dispatch_model=${10:-}
    local dispatch_labels=${11:-}

    # Write prompt to file for reference and @file import
    local prompt_file="/tmp/tmq-prompt-${session_name}.txt"
    echo "$prompt" > "$prompt_file"

    # Convert agent shorthand
    local aoe_tool
    case "$agent" in
        cc) aoe_tool="claude" ;;
        pi) aoe_tool="pi" ;;
        oc) aoe_tool="opencode" ;;
    esac

    # #39: Claude Code refuses --dangerously-skip-permissions under root/sudo,
    # so a cc dispatch on a root host dies instantly (pane exit 1) and then
    # vanishes on the next aoe daemon restart — silent and traceless. Fail fast
    # by default; allow an explicit, opt-in IS_SANDBOX=1 escape hatch for a
    # deliberately autonomous root agent.
    local cc_env_prefix=""
    if [[ "$agent" == "cc" && "$EUID" -eq 0 ]]; then
        if [[ "${TMQ_ALLOW_ROOT_CC:-0}" == "1" ]]; then
            cc_env_prefix="IS_SANDBOX=1 "
            echo "WARNING: spawning an AUTONOMOUS ROOT cc agent (TMQ_ALLOW_ROOT_CC=1)." >&2
            echo "         IS_SANDBOX=1 lets --dangerously-skip-permissions run under root —" >&2
            echo "         no permission guardrails. Deliberate security tradeoff (tms#39)." >&2
        else
            echo "ERROR: cc dispatch refused under root." >&2
            echo "  Claude Code blocks --dangerously-skip-permissions for root/sudo, so the" >&2
            echo "  session would die instantly and vanish without a trace (tms#39)." >&2
            echo "  Options:" >&2
            echo "    * dispatch with --agent pi   (no such restriction), or" >&2
            echo "    * run the issue in a supervised (non-dispatched) Claude session, or" >&2
            echo "    * opt in explicitly:  TMQ_ALLOW_ROOT_CC=1 tmq ... --agent cc" >&2
            echo "      (spawns an autonomous root agent with permissions disabled)." >&2
            return 1
        fi
    fi

    # Build full command line (prompt injection)
    local cmd_override
    case "$agent" in
        # Prompt via stdin (like the oc branch), NOT an inline arg: an unquoted
        # $(cat ... | jq) word-splits the prompt so only its first token reaches
        # -p, and any `--word` in the issue body becomes a stray claude flag
        # (#42). claude -p reads the prompt from stdin.
        cc) cmd_override="cat '$prompt_file' | ${cc_env_prefix}claude --dangerously-skip-permissions -p; echo; echo '--- CLAUDE DONE ---'; exec bash" ;;
        # PI_DISPATCH_AUTOAPPROVE: the safety-guards extension auto-approves its
        # CONFIRM tier (keeps HARD_BLOCK) so a dispatched agent doesn't stall on
        # a permission prompt with no human attached (issue #30). Worktree-isolated.
        # --provider/--model forward to pi when set (#37); empty = pi default.
        pi)
            local pi_extra=""
            [[ -n "$PI_PROVIDER" ]] && pi_extra+=" --provider $PI_PROVIDER"
            [[ -n "$PI_MODEL" ]]    && pi_extra+=" --model $PI_MODEL"
            cmd_override="PI_DISPATCH_AUTOAPPROVE=1 pi${pi_extra} @$prompt_file; echo; echo '--- PI DONE ---'; exec bash"
            ;;
        oc) cmd_override="cat '$prompt_file' | opencode 2>&1; echo; echo '--- OPENCODE DONE ---'; exec bash" ;;
    esac

    # Use Agent of Empires if available (session appears in aoe dashboard + web)
    if command -v aoe &>/dev/null; then
        local wt_flag="" add_ok=0 start_ok=0
        [[ -n "$branch" ]] && wt_flag="-w $branch"

        # `aoe add` may fail (duplicate, network, etc). Capture exit.
        if aoe add "$cwd" -t "$session_name" --tool "$aoe_tool" \
                $wt_flag --trust-hooks \
                --cmd-override "$cmd_override" 2>&1; then
            add_ok=1
        fi

        # Chain `aoe session start` to actually launch the agent.
        # (aoe add alone just registers the session — without start the
        # session sits idle in the dashboard and the agent never runs.)
        if (( add_ok )); then
            aoe session start "$session_name" 2>&1 && start_ok=1 || true
        fi

        # TMS_TMQ_LAUNCH=1: opt-in auto-attach for direct `tmq` invocations.
        # Switches the user's tmux client into the RUNNING session (blocks
        # until detach, which is the whole point — drop straight in). The
        # default (unset) preserves the tms dispatch-then-return flow: fzf
        # returns to the issue list instead of dropping into the agent pane.
        # `start` above already launched the agent, so attach is purely the
        # client switch — it must not replace start (attach alone may not
        # spawn the tmux process). (tms#12)
        if (( start_ok )) && _tmq_want_auto_attach; then
            # `||` with a warning instead of bare `|| true`: a failed attach
            # is cosmetic (the agent already launched via `start` above), but
            # the user opted in to dropping straight in, so tell them it
            # didn't happen rather than falling through silently. (tms#12)
            aoe session attach "$session_name" 2>&1 \
                || echo "WARNING: auto-attach failed; run 'aoe session attach $session_name' to drop in" >&2
        fi

        if (( add_ok && start_ok )); then
            echo "Spawned: $session_name ($agent in $cwd) [via aoe]"
            echo "Prompt:   $prompt_file"
            echo "Monitor:  aoe status"
            echo "Attach:   aoe session attach $session_name   # when ready"
            # Log dispatch event (tms#53). Resolve aoe id prefix for stable join key.
            # TMQ_NO_LOG (tms#57): the independent-review poller logs its own
            # dispatch event with source='poller', so it suppresses tmq's
            # default log to avoid a double event.
            if [[ -n "$dispatch_repo" && -z "${TMQ_NO_LOG:-}" ]]; then
                local aoe_id
                aoe_id=$(aoe session show "$session_name" --json 2>/dev/null | \
                    python3 -c 'import json,sys;print(json.load(sys.stdin)["id"][:8])' 2>/dev/null || echo "")
                PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
                    python3 -m tms.events dispatch \
                    "$dispatch_repo" "$dispatch_issue" "$agent" \
                    "$dispatch_provider" "$dispatch_model" \
                    "$dispatch_type" "$cwd" "$session_name" \
                    "$aoe_id" "${TMQ_DISPATCH_SOURCE:-author}" "$dispatch_labels" 2>/dev/null || true
            fi
        else
            # Honest failure. Clean up the half-registered session so it
            # doesn't dangle in `aoe list` waiting for manual cleanup.
            if (( add_ok && ! start_ok )); then
                echo "ERROR: agent did not start (see aoe output above)" >&2
                echo "  cleaning up the half-registered session..." >&2
                aoe remove "$session_name" >&2 || true
            else
                echo "ERROR: aoe add failed (see output above)" >&2
                echo "  (likely duplicate title, missing worktree, or invalid tool)" >&2
            fi
            # Log dispatch_failed event (tms#53) before returning.
            # TMQ_NO_LOG (tms#57): poller suppresses to avoid double event.
            if [[ -n "$dispatch_repo" && -z "${TMQ_NO_LOG:-}" ]]; then
                local reason
                if (( add_ok && ! start_ok )); then
                    reason="aoe session start failed"
                else
                    reason="aoe add failed"
                fi
                PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
                    python3 -m tms.events dispatch-failed \
                    "$dispatch_repo" "$dispatch_issue" "$agent" \
                    "$dispatch_provider" "$dispatch_model" \
                    "$dispatch_type" "$reason" 2>/dev/null || true
            fi
            return 1
        fi
    else
        # Fallback: direct tmux spawn (no aoe dashboard visibility)
        case "$agent" in
            cc)
                tmux new-session -d -s "$session_name" -c "$cwd" \
                    "cat '$prompt_file' | ${cc_env_prefix}claude --dangerously-skip-permissions -p; echo; echo '--- CLAUDE DONE ---'; exec bash"
                ;;
            pi)
                local pi_extra=""
                [[ -n "$PI_PROVIDER" ]] && pi_extra+=" --provider $PI_PROVIDER"
                [[ -n "$PI_MODEL" ]]    && pi_extra+=" --model $PI_MODEL"
                tmux new-session -d -s "$session_name" -c "$cwd" \
                    "pi${pi_extra} @$prompt_file; echo; echo '--- PI DONE ---'; exec bash"
                ;;
            oc)
                tmux new-session -d -s "$session_name" -c "$cwd" \
                    "cat '$prompt_file' | opencode 2>&1; echo; echo '--- OPENCODE DONE ---'; exec bash"
                ;;
        esac
        echo "Spawned: $session_name ($agent in $cwd)"
        echo "Prompt:   $prompt_file"
        echo "Attach:   tmux a -t $session_name"
        # Log dispatch event (tms#53) — no aoe id prefix in fallback mode.
        # TMQ_NO_LOG (tms#57): poller suppresses to avoid a double event.
        if [[ -n "$dispatch_repo" && -z "${TMQ_NO_LOG:-}" ]]; then
            PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
                python3 -m tms.events dispatch \
                "$dispatch_repo" "$dispatch_issue" "$agent" \
                "$dispatch_provider" "$dispatch_model" \
                "$dispatch_type" "$cwd" "$session_name" "" \
                "${TMQ_DISPATCH_SOURCE:-author}" "$dispatch_labels" 2>/dev/null || true
        fi
    fi
}

# ── worktree management ──────────────────────────────────────────

# Globals: set by create_worktree, read by main() + build_prompt()
TMQ_CWD=""
TMQ_BRANCH=""
# Set to 1 by create_worktree when review reuses a feat session's worktree.
# Decoupled from TMQ_BRANCH so detached-HEAD doesn't make the prompt
# mis-report "no feat session to reuse" while the worktree IS being reused.
TMQ_REUSED=0
# Set to 1 by create_worktree when the reused feat session's tmux is alive.
# Drives whether the prompt can claim the feat agent will see fixups.
TMQ_FEAT_LIVE=0
# Set by main() for review type: the resolved PR number (issue→PR fallback).
# build_prompt() reads this instead of calling resolve_pr_number again,
# avoiding duplicate gh API calls (#10 review, P1).
TMQ_REVIEW_PR_NUM=""

# Find an existing feat-<repo>#<num> aoe session and return its
# worktree path (the caller reads the branch separately via git).
# Empty stdout + non-zero exit if no live session is found.
#
# When multiple feat sessions match (e.g. user re-dispatched after a
# crash), pick the most recent by created_at — the older session's
# worktree is the stale one.
#
# Bound the aoe CLI with `timeout` so a hung daemon can't freeze
# `tmq review` indefinitely.
# Globals set by find_feat_session on success (never on failure).
# TMQ_FEAT_PATH      = absolute path to the worktree
# TMQ_FEAT_PREFIX    = which session type matched (feat, fix, or chore)
# TMQ_AOE_ID_PREFIX  = first 8 chars of the aoe session id (for precise
#                       liveness match — avoids broad glob false positives)
TMQ_FEAT_PATH=""
TMQ_FEAT_PREFIX=""
TMQ_AOE_ID_PREFIX=""

find_feat_session() {
    local repo=$1 issue_num=$2

    command -v aoe &>/dev/null || return 1

    local prefix
    for prefix in feat fix chore; do
        local title="${prefix}-${repo}#${issue_num}"

        local entry wt_path aoe_id
        entry=$(timeout 5 aoe list --json 2>/dev/null | \
            jq -r --arg t "$title" '
                [.[] | select(.title == $t)]
                | sort_by(.created_at)
                | last
                | "\(.path // empty)\	\(.id // empty)"
            ' 2>/dev/null) || continue

        wt_path="${entry%%$'\t'*}"
        aoe_id="${entry##*$'\t'}"

        # Path must exist as a directory and be a git worktree
        # (or bare main checkout for non-worktree repos). Skip if stale.
        if [[ -z "$wt_path" ]] || [[ ! -d "$wt_path" ]] \
            || ! git -C "$wt_path" rev-parse --git-dir &>/dev/null; then
            continue
        fi

        TMQ_FEAT_PATH="$wt_path"
        TMQ_FEAT_PREFIX="$prefix"
        # First 8 chars of the aoe id (enough for unique session match)
        TMQ_AOE_ID_PREFIX="${aoe_id:0:8}"
        return 0
    done

    return 1
}

create_worktree() {
    local repo=$1 issue_num=$2 type=$3
    local path="${REPO_PATH[$repo]}"

    # REVIEW TYPE: try to reuse an existing feat-<repo>#<num> session's
    # worktree so the reviewer sees the same code the feature agent is
    # pushing, and fixups land on the same branch.
    if [[ "$type" == "review" ]]; then
        local feat_path feat_branch
        find_feat_session "$repo" "$issue_num" || true
        feat_path="$TMQ_FEAT_PATH"
        if [[ -n "$feat_path" ]]; then
            # Item 2 (#10): non-worktree repos can't reuse — the main
            # checkout isn't a worktree; "shared with the feature agent"
            # wording is misleading (the feat branch is a different ref
            # the reviewer isn't checked out to).
            if (( REPO_WORKTREE[$repo] != 1 )); then
                echo "  skipping reuse: $repo is a non-worktree repo" >&2
            else
                feat_branch=$(git -C "$feat_path" branch --show-current 2>/dev/null)

                # Item 3 (#10): validate the upstream branch still exists
                # on the remote. Skip reuse if it was force-pushed away,
                # deleted, or merged+cleaned (otherwise the prompt's
                # `git pull --ff-only` instruction fails with a confusing
                # error on a dangling branch). Skip validation on detached
                # HEAD (empty branch) — no upstream to check.
                if [[ -n "$feat_branch" ]] \
                    && ! git -C "$feat_path" rev-parse --verify "origin/$feat_branch" &>/dev/null; then
                    echo "  skipping reuse: upstream branch origin/$feat_branch not found (deleted or force-pushed?)" >&2
                else

                # Liveness: use the precise aoe id prefix from
                # find_feat_session, not a broad glob. A glob like
                # `aoe_*-${repo}_${issue_num}_*` would match
                # review- sessions and cross-type ghosts (P0 #2
                # from tms#10 proposal review).
                if [[ -n "$TMQ_AOE_ID_PREFIX" ]]; then
                    local feat_session_pattern="aoe_${TMQ_FEAT_PREFIX}-${repo}_${issue_num}_${TMQ_AOE_ID_PREFIX}*"
                    if tmux has-session -t "$feat_session_pattern" 2>/dev/null; then
                        TMQ_FEAT_LIVE=1
                    fi
                fi

                echo "Reusing ${TMQ_FEAT_PREFIX} session worktree: $feat_path" >&2
                echo "  branch: ${feat_branch:-<detached>}" >&2
                echo "  ${TMQ_FEAT_PREFIX} agent live: $([[ $TMQ_FEAT_LIVE -eq 1 ]] && echo yes || echo no)" >&2
                TMQ_CWD="$feat_path"
                TMQ_BRANCH="$feat_branch"
                TMQ_REUSED=1
                echo "$feat_path"
                return
                fi  # end upstream validation guard
            fi  # end worktree-repo gate (Item 2)
        fi
        # No feat session found — fall through to standard handling
    fi

    # Only create worktrees for feature branches on worktree repos
    if (( REPO_WORKTREE[$repo] != 1 )); then
        git -C "$path" checkout main >/dev/null 2>&1 || true
        TMQ_CWD="$path"
        TMQ_BRANCH=""
        echo "$path"
        return
    fi

    if [[ "$type" != "feature" ]]; then
        git -C "$path" checkout main >/dev/null 2>&1 || true
        git -C "$path" pull --ff-only >/dev/null 2>&1 || true
        TMQ_CWD="$path"
        TMQ_BRANCH=""
        echo "$path"
        return
    fi

    # Feature branch: create worktree
    local issue_json title branch slug wt_path
    issue_json=$(fetch_issue "$repo" "$issue_num")
    title=$(echo "$issue_json" | jq -r '.title')
    branch="feat/issue-${issue_num}-$(slugify "$title" | cut -c1-30 | sed 's/-$//')"
    TMQ_BRANCH="$branch"
    slug="${repo}-${issue_num}"
    wt_path="/root/wt-${slug}"

    # Check if worktree already exists
    if [[ -d "$wt_path" ]]; then
        echo "Worktree already exists: $wt_path" >&2
        TMQ_CWD="$wt_path"
        echo "$wt_path"
        return
    fi

    echo "Creating worktree: $wt_path" >&2
    echo "  branch: $branch" >&2

    # Ensure main is clean (silence all output to stderr or null)
    git -C "$path" fetch origin >/dev/null 2>&1
    git -C "$path" checkout main >/dev/null 2>&1 || true
    git -C "$path" pull --ff-only origin main >/dev/null 2>&1 || true

    # Create branch from main and worktree
    git -C "$path" branch "$branch" main >/dev/null 2>&1 || true
    git -C "$path" worktree add "$wt_path" "$branch" >/dev/null 2>&1

    # Install deps in worktree (per institutional memory gotcha)
    if [[ -f "$wt_path/package.json" ]]; then
        echo "  installing deps..." >&2
        (cd "$wt_path" && bun install --frozen-lockfile >/dev/null 2>&1 || bun install >/dev/null 2>&1) &
    fi

    TMQ_CWD="$wt_path"
    echo "$wt_path"
}

# ── reviewer overlap warning (#55) ───────────────────────────────
# tower-fleet#193 open question 12: warn when the author model
# overlaps the reviewer panel. Hardcoded from ~/.pi/agent/agents/
# reviewer definitions; revisit when bogocat/pi-dotfiles#3 /
# tower-fleet#194 establish the canonical mapping.

# Output: model<TAB>reviewer-name (one per line, may have multiple
# lines per model — claude maps to two reviewers).
_reviewer_panel_map() {
    cat <<'EOF'
deepseek-v4-pro	reviewer
MiniMax-M3	reviewer-m3
claude	reviewer-fast
claude	reviewer-claude
anthropic/claude-sonnet-4.6	reviewer-fast-api
glm-5.2	reviewer-zai
EOF
}

# Warn to stderr when the author model overlaps the reviewer panel.
# $1 = author model ID (may be empty, defaults to pi's default model;
# currently deepseek-v4-pro per ~/.pi/agent/settings.json).
_check_reviewer_overlap() {
    local model="${1:-deepseek-v4-pro}"
    local overlaps
    overlaps=$(_reviewer_panel_map | awk -F'\t' -v m="$model" '$1 == m {print $2}')
    if [[ -n "$overlaps" ]]; then
        local reviewer_list total
        total=$(_reviewer_panel_map | wc -l)
        reviewer_list=$(echo "$overlaps" | paste -sd ',' - | sed 's/,/, /g')
        local overlap_count
        overlap_count=$(echo "$overlaps" | wc -l)
        local remaining=$((total - overlap_count))
        echo "warn: author model $model is also $reviewer_list -- panel independence reduced to $remaining reviewers" >&2
    fi
}

# ── main ─────────────────────────────────────────────────────────

main() {
    # Parse -- flags
    local agent="$DEFAULT_AGENT"
    local type="$ISSUE_TYPE"
    local repo="" number=""
    TMQ_LABELS="[]"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)    agent="$2"; shift 2 ;;
            --type)     type="$2"; shift 2 ;;
            --provider) PI_PROVIDER="$2"; shift 2 ;;
            --model)    PI_MODEL="$2"; shift 2 ;;
            -h|--help) usage ;;
            *)
                if [[ -z "$repo" ]]; then
                    repo="$1"
                elif [[ -z "$number" ]]; then
                    number="$1"
                fi
                shift
                ;;
        esac
    done

    # Validate repo
    if [[ -z "${REPO_PATH[$repo]:-}" ]]; then
        echo "Unknown repo: $repo"
        echo "Known repos: ${!REPO_PATH[*]}"
        exit 1
    fi

    # Validate number
    if [[ -z "$number" ]] || ! [[ "$number" =~ ^[0-9]+$ ]]; then
        echo "Missing or invalid issue number: ${number:-}"
        usage
    fi

    # Validate agent
    case "$agent" in
        cc|pi|oc) ;;
        *) echo "Unknown agent: $agent (use cc, pi, or oc)"; exit 1 ;;
    esac

    # --provider/--model only mean something for pi (forwarded to pi's flags).
    # cc model selection is out of band; oc has no such flag. Fail fast rather
    # than silently ignoring the flag (#37).
    if [[ -n "$PI_PROVIDER" || -n "$PI_MODEL" ]]; then
        if [[ "$agent" != "pi" ]]; then
            echo "Error: --provider/--model only apply to --agent pi (got: $agent)." >&2
            echo "  cc model selection is out of band; oc has no model flag." >&2
            exit 1
        fi
        # Guard against the empty-value footgun ('--model' with no argument
        # would otherwise consume the repo/number as its value).
        [[ -n "$PI_MODEL" && "$PI_MODEL" == -* ]] && {
            echo "Error: --model expects a value (got: '$PI_MODEL')." >&2; exit 1; }
        [[ -n "$PI_PROVIDER" && "$PI_PROVIDER" == -* ]] && {
            echo "Error: --provider expects a value (got: '$PI_PROVIDER')." >&2; exit 1; }
    fi

    # Validate type
    case "$type" in
        feature|fix|chore|review) ;;
        *) echo "Unknown type: $type (use feature, fix, chore, or review)"; exit 1 ;;
    esac

    # #55: warn when the dispatched model overlaps the reviewer panel.
    # Only pi accepts --model; cc/oc model selection is out of band.
    if [[ "$agent" == "pi" ]]; then
        _check_reviewer_overlap "$PI_MODEL"
    fi

    echo "=== tmq: $type ${REPO_GH[$repo]}#$number ($agent) ==="

    # Fetch issue/PR info for display
    if [[ "$type" == "review" ]]; then
        # Item 4 (#10): resolve issue numbers to PR numbers.
        # Store in TMQ_REVIEW_PR_NUM so build_prompt() can reuse it
        # without a duplicate gh API call (#10 review, P1).
        TMQ_REVIEW_PR_NUM=$(resolve_pr_number "$repo" "$number") || {
            echo "ERROR: Could not find PR for ${REPO_GH[$repo]}#$number (not a PR number and no linked PRs found)" >&2
            exit 1
        }
        local pr_json title
        pr_json=$(fetch_pr "$repo" "$TMQ_REVIEW_PR_NUM")
        title=$(echo "$pr_json" | jq -r '.title')
        echo "PR: $title"
        echo "URL: $(echo "$pr_json" | jq -r '.url')"
    else
        local issue_json title
        issue_json=$(fetch_issue "$repo" "$number")
        title=$(echo "$issue_json" | jq -r '.title')
        echo "Issue: $title"
        echo "URL: $(echo "$issue_json" | jq -r '.url')"
        # Extract labels for dispatch metadata enrichment (#76)
        TMQ_LABELS=$(echo "$issue_json" | jq -r '[.labels[].name] | @json' 2>/dev/null || echo '[]')
    fi

    # Set up working directory (worktree for features). Call
    # create_worktree directly (not via $()) so its TMQ_CWD/TMQ_BRANCH
    # globals propagate to this scope — build_prompt and spawn_agent
    # both read them.
    create_worktree "$repo" "$number" "$type"
    local cwd="$TMQ_CWD"

    # Build the prompt
    local prompt
    prompt=$(build_prompt "$repo" "$number" "$type" "$agent")

    # Determine session name
    local session_name
    case "$type" in
        review) session_name="review-${repo}#${number}" ;;
        feature) session_name="feat-${repo}#${number}" ;;
        fix) session_name="fix-${repo}#${number}" ;;
        chore) session_name="chore-${repo}#${number}" ;;
    esac

    # Abbreviate agent in session name
    case "$agent" in
        cc) session_name="${session_name}-cc" ;;
        pi) session_name="${session_name}" ;;     # default, no suffix
        oc) session_name="${session_name}-oc" ;;
    esac

    # Log dispatch_failed on cc-root-refusal (spawn_agent returns 1 fast).
    # Track the exit so we can log success/failure on the other path.
    local spawn_rc=0

    # Spawn (via aoe if available, direct tmux fallback).
    # Pass dispatch metadata (repo, issue, type, provider, model) so
    # spawn_agent can log the event at the success/failure points.
    spawn_agent "$session_name" "$cwd" "$prompt" "$agent" "$TMQ_BRANCH" \
        "$repo" "$number" "$type" "$PI_PROVIDER" "$PI_MODEL" "$TMQ_LABELS" || spawn_rc=$?

    # Log dispatch_failed if spawn_agent returned non-zero but didn't
    # already log it itself (cc-root-refusal returns before the aoe block
    # that does its own dispatch_failed logging).
    if (( spawn_rc != 0 )) && [[ "$agent" == "cc" && "$EUID" -eq 0 ]]; then
        PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
            python3 -m tms.events dispatch-failed \
            "$repo" "$number" "$agent" "$PI_PROVIDER" "$PI_MODEL" \
            "$type" "cc dispatch refused under root" 2>/dev/null || true
    fi

    # Propagate spawn failure to tmq's exit code so the caller (poller,
    # user's shell) can detect the failure. (#77: previously main() always
    # exited 0, making every aoe-add failure invisible to the poller.)
    return $spawn_rc
}

# ── dispatch ─────────────────────────────────────────────────────
# Guarded so the script can be sourced (e.g. by the pytest suite) without
# running the dispatch below — sourcing then exposes every function above
# for unit testing. (tms#12)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    case "${1:-}" in
        list|ls)
            if [[ "${2:-}" == "--machine" ]]; then
                list_repos_machine
            else
                list_repos
            fi
            ;;
        review|pr)
            shift
            main "${@}" --type review
            exit $?
            ;;
        -h|--help)
            usage
            ;;
        *)
            if [[ -z "${1:-}" ]]; then
                usage
            fi
            main "$@"
            exit $?
            ;;
    esac
fi
