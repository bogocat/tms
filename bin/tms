#!/usr/bin/env bash
# tms — tmux session manager with fuzzy preview
#
# Usage:
#   tms                interactive picker → attach
#   tms ls             list sessions with metadata
#   tms kill <name>    kill a session
#   tms rename <name>  rename a session
#   tms clean          kill stale + compact scratch session numbers
#   tms stale          list sessions idle >7 days (checks ALL windows)
#   tms issues [repo|--all] [--force]  browse issues (auto-detects repo from CWD)
#          --all      show all repos
#          --force    skip cache (5-min TTL, /tmp/tms-issues-cache/)
#          --clear-cache  wipe cached issue data
#   tms events transitions  poll aoe + tmux panes, emit transition events
#   tms events stats [opts]  compute and print aggregate metrics report
#   tms events scan-reviews   list open PRs lacking reviewer verdict (#57)
#   tms wraps scan-wraps     scan terminal transitions, dispatch objective wraps (#82)
#
# Keybindings in fzf:
#   enter     attach to session (switch client)
#   ctrl-x/d  kill session (with confirmation)
#   ctrl-r    rename session
#   ctrl-p    preview only (peek without attaching)
#   ctrl-k    clean stale sessions + compact scratch numbers
#   ?         show help in preview pane

set -euo pipefail

STALE_DAYS=7
NOW=$(date +%s)
ISSUE_CACHE_DIR=/tmp/tms-issues-cache
ISSUE_CACHE_TTL=300  # 5 minutes

# ── helpers ──────────────────────────────────────────────────────

session_age_seconds() {
    local created
    created=$(tmux display-message -t "$1" -p '#{session_created}' 2>/dev/null) || echo 0
    echo $((NOW - created))
}

session_age_human() {
    local secs=$1
    if   (( secs < 3600 ));       then echo "$((secs / 60))m ago"
    elif (( secs < 86400 ));      then echo "$((secs / 3600))h ago"
    elif (( secs < 604800 ));     then echo "$((secs / 86400))d ago"
    else                               echo "$((secs / 604800))w ago"
    fi
}

detect_agent() {
    local cmd=$1
    case "$cmd" in
        pi)       echo "π" ;;
        claude)   echo "cc" ;;
        opencode) echo "oc" ;;
        python3)  echo "py" ;;
        bash)     echo "sh" ;;
        zsh)      echo "sh" ;;
        *)        echo "${cmd:0:3}" ;;
    esac
}

# Check ALL panes in ALL windows. A session is stale only if every
# pane is sitting at a shell prompt and the session is old + unattached.
is_session_stale() {
    local name=$1
    local age_sec attached

    age_sec=$(session_age_seconds "$name")
    (( age_sec <= STALE_DAYS * 86400 )) && return 1

    attached=$(tmux list-sessions -F "#{session_attached}" -f "#{==:#{session_name},$name}" 2>/dev/null)
    (( attached > 0 )) && return 1

    # Check every pane — if ANY pane is running something non-shell, it's active
    local panes
    panes=$(tmux list-panes -t "$name" -F "#{pane_current_command}" 2>/dev/null) || return 1

    while IFS= read -r cmd; do
        [[ -z "$cmd" ]] && continue
        case "$cmd" in
            bash|zsh|fish|sh|dash) ;;  # shell prompt = idle
            *) return 1 ;;              # anything else = active work
        esac
    done <<< "$panes"

    return 0  # all panes idle → stale
}

# ── agent status lookup (Running/Waiting/Idle from aoe) ─────────
# For aoe-managed sessions, fetch the daemon's notion of state.
# For raw tmux sessions, derive a coarse status from the pane cmd:
#   pi|claude|opencode|codex|cursor → "run"  (agent is the foreground process)
#   bash|zsh|fish|sh|dash            → "idle" (sat at a prompt)
#   anything else                    → "run"  (background worker of some kind)
#
# Aoe statuses: running | waiting | idle | error | stopped
# We map them to compact 4-char labels for the picker column.

AOE_STATUS_CACHE=/tmp/tms-aoe-status-cache.json
AOE_STATUS_TTL=10

# Build a temp file mapping aoe_title → status. Cached for AOE_STATUS_TTL.
# File format: title<TAB>status (one per line)
_aoe_status_map() {
    if [[ -f "$AOE_STATUS_CACHE" ]]; then
        local age
        age=$(($(date +%s) - $(stat -c %Y "$AOE_STATUS_CACHE" 2>/dev/null || echo 0)))
        if (( age < AOE_STATUS_TTL )); then
            echo "$AOE_STATUS_CACHE"
            return
        fi
    fi

    if ! command -v aoe &>/dev/null; then
        # No aoe → empty cache, no statuses. Don't write a file: keep the
        # 'aoe missing' check live for the next call (a freshly installed
        # aoe is picked up immediately).
        return 1
    fi

    # Delegate to the lib/tms/aoe_status module (extracted from this
    # heredoc in issue #8). The module does its own atomic write
    # (lib/tms/atomic.py: tmp + os.replace), so a concurrent reader
    # never sees a half-written file. P0#2 fix (narrowed exceptions)
    # lives in the module.
    if ! PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
            python3 -m tms.aoe_status "$AOE_STATUS_CACHE" 2>/dev/null; then
        return 1
    fi

    echo "$AOE_STATUS_CACHE"
}

# Map aoe status string → 4-char label + ANSI color code
_format_status() {
    local s=$1
    case "$s" in
        running)  printf 'run '  ;;  # green bold
        waiting)  printf 'wait'  ;;  # yellow bold
        idle)     printf 'idle'  ;;  # dim
        error)    printf 'err '  ;;  # red bold
        stopped)  printf 'stop'  ;;  # red dim
        stale:*)  printf 'stal'  ;;  # magenta bold (stale watchdog #56)
        *)        printf '—   '  ;;
    esac
}

_status_color() {
    local s=$1
    case "$s" in
        running)  echo '32;1' ;;
        waiting)  echo '33;1' ;;
        idle)     echo '2' ;;
        error)    echo '31;1' ;;
        stopped)  echo '31;2' ;;
        stale:*)  echo '35;1' ;;  # magenta bold (stale watchdog #56)
        *)        echo '2' ;;
    esac
}

# Public: resolve the status for a given session.
# Args: $1 = tmux session name, $2 = status map file path (may be empty)
# Outputs: "<colored_status_text><reset>"
_session_status() {
    local name=$1 map_file=$2

    # aoe-managed session: look up in the status map
    if [[ "$name" == aoe_* ]]; then
        if [[ -n "$map_file" && -f "$map_file" ]]; then
            local compact
            compact=$(compact_session_name "$name")
            if [[ -n "$compact" ]]; then
                local hit
                hit=$(grep -F "${compact}"$'\t' "$map_file" 2>/dev/null | head -1 || true)
                if [[ -n "$hit" ]]; then
                    local s color
                    s=$(echo "$hit" | cut -f2)
                    local status_text
                    status_text=$(_format_status "$s")
                    color=$(_status_color "$s")
                    printf '\033[%sm%s\033[0m' "$color" "$status_text"
                    return
                fi
            fi
        fi
        # aoe session but no map (aoe missing) or no hit → show placeholder
        # (NOT the pane-cmd heuristic, which would lie for aoe sessions)
        printf '\033[2m—   \033[0m'
        return
    fi

    # Non-aoe session: derive from pane cmd
    local cmd
    cmd=$(tmux list-panes -t "$name" -F "#{pane_current_command}" 2>/dev/null | head -1)
    case "$cmd" in
        pi|claude|opencode|codex|cursor)
            printf '\033[32;1mrun \033[0m' ;;
        bash|zsh|fish|sh|dash)
            printf '\033[2midle\033[0m' ;;
        "")
            printf '\033[2m—   \033[0m' ;;
        *)
            # Background worker or unknown — assume active
            printf '\033[32;1mrun \033[0m' ;;
    esac
}

# ── issue status lookup (for session list coloring) ──────────────

# Build a mapping from "repo#num" → "sym|status|color_code"
# Reads cached NDJSON files (fast, no network)
_issue_status_lookup() {
    local cache_dir="$ISSUE_CACHE_DIR"
    [[ -d "$cache_dir" ]] || { echo ""; return; }

    python3 - "$cache_dir" << 'PYEOF'
import json, sys, os, glob

R='\033[31m'; G='\033[32m'; Y='\033[33m'; B='\033[34m'
M='\033[35m'; C='\033[36m'; D='\033[2m'; N='\033[0m'; BOLD='\033[1m'

cache_dir = sys.argv[1]
for f in sorted(glob.glob(os.path.join(cache_dir, '*.ndjson'))):
    try:
        with open(f) as fh:
            for line in fh:
                line = line.strip()
                if not line:
                    continue
                iss = json.loads(line)
                key = f"{iss['repo']}#{iss['number']}"
                status = iss.get('status', '')
                labels = iss.get('labels', '').lower()

                if 'blocked' in labels:
                    print(f"{key}\t✗\tblocked\t31")
                elif 'question' in labels:
                    print(f"{key}\t?\tquestion\t35")
                elif 'reviewed' in labels:
                    print(f"{key}\t✔\treviewed\t32")
                elif status == 'ready-to-merge':
                    print(f"{key}\t✓\tready\t32")
                elif status == 'pending-review':
                    print(f"{key}\t◎\treview\t33")
                elif status == 'in progress':
                    print(f"{key}\t▶\tpr open\t34")
                else:
                    # Open issue — session_info will color it cyan (has agent)
                    print(f"{key}\t○\topen\t0")
    except Exception:
        continue
PYEOF
}

# Compact session name for display (strip aoe_ prefix + UUID suffix)
compact_session_name() {
    local name=$1
    # tmq sessions: already short, keep as-is
    if [[ "$name" =~ ^(feat|fix|chore|review)- ]]; then
        echo "$name"
        return
    fi
    # aoe sessions: aoe_feat-home-portal_5_f3cc709e → feat-home-portal#5
    if [[ "$name" == aoe_* ]]; then
        local stripped="${name#aoe_}"       # feat-home-portal_5_f3cc709e
        local uuid="${stripped##*_}"        # f3cc709e
        if [[ "$uuid" =~ ^[0-9a-f]{6,}$ ]]; then
            stripped="${stripped%_$uuid}"   # feat-home-portal_5
        fi
        # Replace _ with # for the issue number part: feat-home-portal_5 → feat-home-portal#5
        if [[ "$stripped" =~ _([0-9]+)$ ]]; then
            stripped="${stripped%_${BASH_REMATCH[1]}}#${BASH_REMATCH[1]}"
        fi
        echo "$stripped"
        return
    fi
    # Everything else: keep as-is
    echo "$name"
}

session_info() {
    local name=$1
    local status_map="${2:-}"    # temp file: key\tsym\tstatus\tcolor
    local session_issue="${3:-}" # pre-resolved issue key (for aoe sessions)
    local aoe_status_map="${4:-}" # temp file: aoe_title\tstatus
    local cmd cwd attached wins age_sec

    cmd=$(tmux list-panes -t "$name" -F "#{pane_current_command}" 2>/dev/null | head -1)
    cwd=$(tmux list-panes -t "$name" -F "#{pane_current_path}" 2>/dev/null | head -1)
    attached=$(tmux list-sessions -F "#{session_attached}" -f "#{==:#{session_name},$name}" 2>/dev/null)
    wins=$(tmux list-sessions -F "#{session_windows}" -f "#{==:#{session_name},$name}" 2>/dev/null)
    age_sec=$(session_age_seconds "$name")

    # Resolve agent status (aoe: running/waiting/idle/error/stopped;
    # non-aoe: derived from pane cmd)
    local status_col
    status_col=$(_session_status "$name" "$aoe_status_map")

    # Shorten cwd
    local short_cwd="$cwd"
    short_cwd="${short_cwd/#\/root/}"
    short_cwd="${short_cwd/#\/home/}"
    [[ -z "$short_cwd" ]] && short_cwd="/"
    short_cwd="${short_cwd#/}"

    local agent_icon
    agent_icon=$(detect_agent "$cmd")

    local att_marker=" "
    (( attached > 0 )) && att_marker="*"

    local age_str
    age_str=$(session_age_human "$age_sec")

    local stale_flag=" "
    if is_session_stale "$name"; then
        stale_flag="⚰"
    fi

    # Multi-window indicator
    local win_mark="$wins"
    (( wins > 1 )) && win_mark="${wins}w"

    # Compact session display name
    local display_name
    display_name=$(compact_session_name "$name")

    # Detect linked issue + color
    local issue="—"
    local issue_key=""

    if [[ "$name" =~ ^(feat|fix|chore|review)-(.+)#([0-9]+) ]]; then
        issue_key="${BASH_REMATCH[2]}#${BASH_REMATCH[3]}"
    fi
    if [[ -z "$issue_key" && -n "$session_issue" ]]; then
        issue_key="$session_issue"
    fi

    if [[ -n "$issue_key" ]]; then
        if [[ -n "$status_map" && -f "$status_map" ]]; then
            local lookup
            lookup=$(grep "^${issue_key}"$'\t' "$status_map" 2>/dev/null | head -1 || true)
            if [[ -n "$lookup" ]]; then
                local sym status_text color_code
                sym=$(echo "$lookup" | cut -f2)
                color_code=$(echo "$lookup" | cut -f4)
                [[ "$color_code" == "0" ]] && color_code="36;1"
                local ec nc
                printf -v ec '\033[%sm' "$color_code"
                printf -v nc '\033[0m'
                issue="${ec}${sym} ${issue_key}${nc}"
            else
                issue="${issue_key}"
            fi
        else
            issue="${issue_key}"
        fi
    fi

    # Use real name for fzf selection (first field = awk {print $1})
    # But display compact: aoe_ prefix + UUID stripped if possible
    local disp_name
    disp_name=$(compact_session_name "$name")
    # Truncate if needed
    if (( ${#disp_name} > 28 )); then
        disp_name="${disp_name:0:25}…"
    fi

    # Output real name as invisible last column (tab-separated, fzf strips ANSI
    # but keeps text — preview/attach use real name from {1})
    # Columns: SESSION(28) att(1) AG(1) ST(5) #W(3) AGE(7) stale(1) ISSUE(24) CWD + \t realname
    printf "%-28s %s%-1s %-5s %-3s %-7s %-3s %-24s %s\t%s\n" \
        "$disp_name" "$att_marker" "$agent_icon" "$status_col" "$win_mark" "$age_str" "$stale_flag" "$issue" "$short_cwd" "$name"
}

session_list() {
    # Build issue status lookup (fast — reads from cache)
    local status_map
    status_map=$(mktemp /tmp/tms-session-status-XXXXXX.tsv)
    _issue_status_lookup > "$status_map" 2>/dev/null || true

    # Build aoe agent-status lookup (Running/Waiting/Idle from aoe daemon)
    local aoe_status_map
    aoe_status_map=$(_aoe_status_map 2>/dev/null || echo "")

    # Build session→issue map for aoe sessions (invert the session map)
    local sess_map
    sess_map=$(_cached_session_map 2>/dev/null || echo "")
    local aoe_issues
    aoe_issues=$(mktemp /tmp/tms-aoe-issues-XXXXXX.tsv)
    if [[ -n "$sess_map" && -s "$sess_map" ]]; then
        python3 -c "
import json, sys
m = json.load(open('$sess_map'))
for key, sessions in m.items():
    for s in sessions:
        name = s.split(' ')[0]
        print(f'{name}\t{key}')
" > "$aoe_issues" 2>/dev/null || true
    fi

    printf "%-28s %-4s %-3s %-5s %-3s %-7s %-3s %-24s %s\n" \
        "SESSION" " " "AG" "ST" "#W" "AGE" " " "ISSUE" "CWD"
    printf "%s\n" "────────────────────────────────────────────────────────────────────────────────"

    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | sort)
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        local sess_issue=""
        # Look up aoe session → issue mapping
        if [[ -s "$aoe_issues" ]]; then
            sess_issue=$(grep "^${name}"$'\t' "$aoe_issues" 2>/dev/null | head -1 | cut -f2 || true)
        fi
        session_info "$name" "$status_map" "$sess_issue" "$aoe_status_map"
    done <<< "$sessions"

    # Don't delete the aoe_status_map cache (TTL'd in _aoe_status_map)
    rm -f "$status_map" "$aoe_issues"
}

# ── actions ──────────────────────────────────────────────────────

attach_session() {
    local name=$1
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$name"
    else
        tmux attach-session -t "$name"
    fi
}

kill_session() {
    local name=$1 force="${2:-}"
    if [[ "$force" == "--force" ]]; then
        tmux kill-session -t "$name" 2>/dev/null && echo "Killed $name." || echo "Failed to kill $name."
        return
    fi
    printf "Kill session '%s'? [y/N] " "$name"
    read -r ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
        tmux kill-session -t "$name" 2>/dev/null && echo "Killed." || echo "Failed."
    fi
}

rename_session() {
    local name=$1
    printf "New name for '%s': " "$name"
    read -r newname
    if [[ -n "$newname" ]]; then
        tmux rename-session -t "$name" "$newname" 2>/dev/null && echo "Renamed to $newname." || echo "Failed."
    fi
}

# ── stale detection (all windows) ────────────────────────────────

stale_sessions() {
    printf "%-20s %-7s %-4s %s\n" "SESSION" "AGE" "WINS" "WINDOWS"
    printf "%s\n" "──────────────────────────────────────────────────"
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if is_session_stale "$name"; then
            local age_sec wins cwd
            age_sec=$(session_age_seconds "$name")
            wins=$(tmux list-sessions -F "#{session_windows}" -f "#{==:#{session_name},$name}" 2>/dev/null)
            cwd=$(tmux list-panes -t "$name" -F "#{pane_current_path}" 2>/dev/null | head -1)
            local win_detail
            win_detail=$(tmux list-windows -t "$name" -F "#{window_index}:#{pane_current_command}" 2>/dev/null | tr '\n' ' ')
            printf "%-20s %-7s %-4s %s  (%s)\n" \
                "$name" "$(session_age_human "$age_sec")" "$wins" "$cwd" "$win_detail"
        fi
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null | sort)"
}

# ── compact scratch sessions ─────────────────────────────────────

# After killing stale sessions, renumber single-letter-prefix sessions
# so they're contiguous.  c0,c4,c5 → c0,c1,c2.  Skips attached sessions.
compact_scratch_sessions() {
    local prefixes=()

    # Find which single-letter prefixes exist
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if [[ "$name" =~ ^([a-z])([0-9]+)$ ]]; then
            local p="${BASH_REMATCH[1]}"
            # Only collect each prefix once
            [[ " ${prefixes[*]:-} " != *" $p "* ]] && prefixes+=("$p")
        fi
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null)"

    for prefix in "${prefixes[@]}"; do
        local -a remaining=()
        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            if [[ "$name" =~ ^${prefix}[0-9]+$ ]]; then
                remaining+=("$name")
            fi
        done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${prefix}[0-9]\+$" | sort -V)"

        local idx=0
        local renamed=0
        for s in "${remaining[@]}"; do
            local target="${prefix}${idx}"
            if [[ "$s" != "$target" ]]; then
                local att
                att=$(tmux list-sessions -F "#{session_attached}" -f "#{==:#{session_name},$s}" 2>/dev/null)
                if (( att > 0 )); then
                    echo "  skip $s → $target (attached, rename manually)"
                else
                    tmux rename-session -t "$s" "$target" 2>/dev/null && \
                        echo "  $s → $target" && renamed=1
                fi
            fi
            ((idx++))
        done
        (( renamed )) && echo "  (${prefix}* compacted)" || true
    done
}

# ── issue browser ─────────────────────────────────────────────────
# tms issues — browse open GitHub issues across repos with pipeline
# status (open / in progress / pending review / ready to merge).

# ── registry: derived from `tmq list --machine` (single source of truth) ──
# Cached for 60s; tmq is the canonical registry, tms reads it.
_TMQ_REGISTRY_CACHE=/tmp/tms-tmq-registry-cache.tsv
_TMQ_REGISTRY_TTL=60

_tmq_registry() {
    if [[ -f "$_TMQ_REGISTRY_CACHE" ]]; then
        local age
        age=$(($(date +%s) - $(stat -c %Y "$_TMQ_REGISTRY_CACHE" 2>/dev/null || echo 0)))
        if (( age < _TMQ_REGISTRY_TTL )); then
            cat "$_TMQ_REGISTRY_CACHE"
            return
        fi
    fi
    if ! command -v tmq &>/dev/null; then
        echo "ERROR: tmq not found (tms needs it for repo registry)" >&2
        return 1
    fi
    # Atomic write: tee to a temp file then mv, so a concurrent reader
    # never sees a half-written line.
    local tmp="${_TMQ_REGISTRY_CACHE}.new.$$"
    tmq list --machine | tee "$tmp"
    mv -f "$tmp" "$_TMQ_REGISTRY_CACHE"
}

# Look up the GitHub slug for a shortname. Outputs `short:gh` lines, filtered.
# Replaces the heredoc `issue_repos()`.
issue_repos() {
    _tmq_registry | awk -F'\t' '{print $1 ":" $3}'
}

# Map a directory path to a repo shortname.
# Strategy: match the cwd against registered repo paths, longest first.
# Handles worktrees at /root/wt-<short>-<issue> by matching the shortname
# in the path component after `wt-`.
detect_repo_from_cwd() {
    local dir="${1:-$PWD}"
    local reg best="" bestlen=0
    while IFS=$'\t' read -r short path _ _; do
        [[ -z "$short" ]] && continue
        # Exact path match (or subpath of it)
        if [[ "$dir" == "$path" || "$dir" == "$path"/* ]]; then
            local len=${#path}
            if (( len > bestlen )); then
                best=$short; bestlen=$len
            fi
        fi
    done < <(_tmq_registry)
    if [[ -n "$best" ]]; then echo "$best"; return; fi
    # Worktree convention: /wt-<short>-<num> anywhere in the path.
    # Bash =~ is unanchored, so this works for /root/wt-distillery-108.
    if [[ "$dir" =~ /wt-([a-z0-9-]+)-[0-9]+(/|$) ]]; then
        local candidate="${BASH_REMATCH[1]}"
        if _tmq_registry | awk -F'\t' -v c="$candidate" '$1 == c {found=1} END{exit !found}'; then
            echo "$candidate"; return
        fi
    fi
    # Last resort: any path component matching a shortname
    while IFS=$'\t' read -r short path _ _; do
        [[ -z "$short" ]] && continue
        if [[ "$dir" == *"/$short"* || "$dir" == *"/$short/"* ]]; then
            echo "$short"; return
        fi
    done < <(_tmq_registry)
}

# Is $1 a known repo shortname? Used by the dispatch decision in the picker.
is_known_repo() {
    local short="$1"
    [[ -z "$short" ]] && return 1
    _tmq_registry | awk -F'\t' -v s="$short" '$1 == s {found=1} END{exit !found}'
}

# Cache helpers
_cache_file() { echo "$ISSUE_CACHE_DIR/$1.ndjson"; }

_cache_valid() {
    local cf
    cf=$(_cache_file "$1")
    [[ -f "$cf" ]] || return 1
    local age
    age=$(($NOW - $(stat -c %Y "$cf" 2>/dev/null || echo 0)))
    (( age < ISSUE_CACHE_TTL ))
}

_read_cache() {
    local cf
    cf=$(_cache_file "$1")
    [[ -f "$cf" ]] && cat "$cf"
}

_write_cache() {
    mkdir -p "$ISSUE_CACHE_DIR"
    cat - > "$(_cache_file "$1")"
}

_clear_cache() {
    rm -rf "$ISSUE_CACHE_DIR"
    mkdir -p "$ISSUE_CACHE_DIR"
}

# Fetch issues + PRs for a single repo, output NDJSON with pipeline status
fetch_repo_issues() {
    local short=$1 gh_repo=$2
    local tmp=/tmp/tms-issues-$$-$short

    # Fetch open issues + PRs to temp files
    gh issue list --repo "$gh_repo" --state open \
        --limit 300 --json number,title,labels,url,createdAt,updatedAt > "$tmp.issues" 2>/dev/null || return

    gh pr list --repo "$gh_repo" --state open \
        --limit 300 --json number,title,body,headRefName,reviewDecision,url > "$tmp.prs" 2>/dev/null || echo '[]' > "$tmp.prs"

    # Single python pass: enrich issues with PR status
    python3 - "$tmp.issues" "$tmp.prs" "$short" << 'PYEOF'
import json, sys, re

with open(sys.argv[1]) as f:
    issues = json.load(f)
with open(sys.argv[2]) as f:
    prs = json.load(f)
short_name = sys.argv[3]

pr_status = {}
for pr in prs:
    # Branch: feat/issue-68-*
    m = re.search(r'issue-(\d+)', pr.get('headRefName',''))
    if not m:
        # Title: "... (#68)"
        m = re.search(r'\(#(\d+)\)', pr.get('title',''))
    if not m:
        # Body: closes/fixes/resolves #68
        m = re.search(r'(?:close|fix|resolve)[sd]?\s+#(\d+)', pr.get('body',''), re.I)
    if m:
        num = int(m.group(1))
        rd = pr.get('reviewDecision','') or ''
        status = 'in progress'
        if rd == 'APPROVED': status = 'ready-to-merge'
        elif rd in ('REVIEW_REQUIRED','CHANGES_REQUESTED'): status = 'pending-review'
        pr_status[num] = (pr['number'], status)

for iss in issues:
    num = iss['number']
    labels = ' '.join(l['name'] for l in iss.get('labels',[]))
    status = pr_status.get(num, (None, 'open issue'))[1]
    out = {
        'repo': short_name,
        'number': num,
        'title': iss['title'],
        'labels': labels,
        'status': status,
        'createdAt': iss.get('createdAt', ''),
        'updatedAt': iss.get('updatedAt', ''),
    }
    print(json.dumps(out))
PYEOF
    rm -f "$tmp.issues" "$tmp.prs"
}

# Fetch all issues across repos, output NDJSON
# Optional $1 filters to a single repo shortname
# Uses cache unless $2 == "--force"
fetch_all_issues() {
    local filter="${1:-}" force="${2:-}"
    local -a repos_to_fetch=()
    while IFS=: read -r short gh_repo; do
        [[ -n "$filter" && "$short" != "$filter" ]] && continue
        repos_to_fetch+=("$short:$gh_repo")
    done <<< "$(issue_repos)"

    mkdir -p "$ISSUE_CACHE_DIR"
    for entry in "${repos_to_fetch[@]}"; do
        local short="${entry%%:*}" gh_repo="${entry##*:}"
        if [[ "$force" != "--force" ]] && _cache_valid "$short"; then
            _read_cache "$short"
        else
            fetch_repo_issues "$short" "$gh_repo" 2>/dev/null | tee "$(_cache_file "$short")"
        fi
    done
}

# Build session → issue mapping (JSON: repo#num → [agent info])
# Delegates to lib/tms/session_map.py (extracted in issue #8). The
# module batches into a single tmux call + single git sweep for speed,
# and closes the P1#1 / P1#2 / P1#3 regressions from PR #7's review.
_issue_session_map() {
    local tmp="/tmp/tms-session-map-$$.json"
    PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
        python3 -m tms.session_map "$tmp" 2>/dev/null
    echo "$tmp"
}

# Cached wrapper for session map (TTL 15s — sessions don't change fast)
_cached_session_map() {
    local cache_file="/tmp/tms-session-map-cache.json"
    local ttl=15
    if [[ -f "$cache_file" ]]; then
        local age=$(($(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || echo 0)))
        if (( age < ttl )); then
            echo "$cache_file"
            return
        fi
    fi
    local map_file
    map_file=$(_issue_session_map)
    # `mv` is atomic on the same filesystem (both /tmp). Replaces the
    # previous `cp`+`rm` pattern, which was non-atomic and could leave
    # a concurrent reader seeing a partial file. P0#1 (cache-race fix).
    mv "$map_file" "$cache_file"
    echo "$cache_file"
}

# Format issues for display (fzf input) — single Python pass for speed
issue_list() {
    local repo_filter="${1:-}" force_flag="${2:-}"

    # Build session map (identifies which agents work on which issues)
    local map_file
    map_file=$(_cached_session_map)

    printf "%-12s %-5s %-3s %-7s %-6s %-4s %-4s %s\n" "REPO" "#" "ST" "STATUS" "AGENT" "AGE" "UPD" "TITLE"
    printf "%s\n" "─────────────────────────────────────────────────────────────────"

    # Pipe all NDJSON through a single Python process — avoids spawning
    # python3 per-field/per-line (was 5+ processes per issue)
    local map_arg=""
    [[ -s "$map_file" ]] && map_arg="$map_file"

    local pyfmt
    pyfmt=$(mktemp /tmp/tms-fmt-XXXXXX.py)
    cat > "$pyfmt" << 'PYEOF'
import json, sys

# ANSI helpers
R = '\033[31m'; G = '\033[32m'; Y = '\033[33m'; B = '\033[34m'
M = '\033[35m'; C = '\033[36m'; W = '\033[37m'; D = '\033[2m'; N = '\033[0m'
BOLD = '\033[1m'

def color(c, s):
    return f'{c}{s}{N}'

# Load session map
sessions = {}
if len(sys.argv) > 1 and sys.argv[1]:
    with open(sys.argv[1]) as f:
        sessions = json.load(f)

# Agent icon extraction from session names like "feat-distillery#245-oc π"
def agent_icons(key):
    if key not in sessions:
        return ''
    icons = []
    for s in sessions[key]:
        # s is like "feat-distillery#245-oc π" — grab the icon after the space
        parts = s.rsplit(' ', 1)
        if len(parts) == 2:
            icons.append(parts[1])
        else:
            icons.append(s)
    return ' '.join(icons[:2])

# Status detection
def get_status(iss):
    status = iss.get('status', '')
    labels = iss.get('labels', '').lower()
    key = f'{iss["repo"]}#{iss["number"]}'
    has_agent = bool(agent_icons(key))

    # Label-based overrides (check before PR status)
    if 'blocked' in labels:
        return ('✗', 'blocked', R)
    if 'question' in labels:
        return ('?', 'question', M)
    if 'reviewed' in labels:
        return ('✔', 'reviewed', G)

    # PR-based status
    if status == 'ready-to-merge':
        return ('✓', 'ready', G)
    if status == 'pending-review':
        return ('◎', 'review', Y)
    if status == 'in progress':
        return ('▶', 'pr open', B)
    if has_agent:
        return ('●', 'active', C + BOLD)
    return ('○', 'open', D)

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        iss = json.loads(line)
    except json.JSONDecodeError:
        continue

    repo = iss.get('repo', '')
    if not repo:
        continue
    num = iss.get('number', '')
    title = iss.get('title', '')
    created_at = iss.get('createdAt', '')
    updated_at = iss.get('updatedAt', '')

    sym, status_text, status_color = get_status(iss)
    key = f'{repo}#{num}'
    agents = agent_icons(key)

    # Color the symbol and status
    sym_colored = color(status_color, sym)
    status_colored = color(status_color, f'{status_text:<7}')

    # Agent column: color icons if present, dim dash if not
    if agents:
        agent_colored = color(C + BOLD, f'{agents:<6}')
    else:
        agent_colored = color(D, '—'.ljust(6))

    # AGE / UPD columns (compact 4-char formatter; dim color)
    from datetime import datetime, timezone
    def _age(iso):
        if not iso: return '—'
        try:
            ts = datetime.fromisoformat(iso.replace('Z', '+00:00')).timestamp()
            diff = max(0, datetime.now(timezone.utc).timestamp() - ts)
        except Exception:
            return '—'
        if   diff < 60:       return f'{int(diff)}s'
        elif diff < 3600:     return f'{int(diff // 60)}m'
        elif diff < 86400:    return f'{int(diff // 3600)}h'
        elif diff < 604800:   return f'{int(diff // 86400)}d'
        elif diff < 2592000:  return f'{int(diff // 604800)}w'
        elif diff < 31536000: return f'{int(diff // 2592000)}mo'
        else:                 return f'{int(diff // 31536000)}y'
    age_str = color(D, _age(created_at))
    upd_str = color(D, _age(updated_at))

    # Title: dim if open+no-agent, otherwise normal
    if sym == '○':
        title = color(D, title)

    # Truncate title to fit terminal
    print(f'{repo:<12} #{num:<4}  {sym_colored} {status_colored} {agent_colored} {age_str:<4} {upd_str:<4} {title}')
PYEOF

    fetch_all_issues "$repo_filter" "$force_flag" | python3 "$pyfmt" "$map_arg"
    rm -f "$pyfmt"

    # Session map is shared cache, don't delete
}

# Issue preview (body + linked PRs)
issue_preview() {
    local line=$1 repo num
    repo=$(echo "$line" | awk '{print $1}')
    num=$(echo "$line" | awk '{print $2}' | tr -d '#')

    local gh_repo
    gh_repo=$(issue_repos | grep "^${repo}:" | cut -d: -f2)

    echo "── Issue: $gh_repo#$num ──"
    echo ""
    gh issue view "$num" --repo "$gh_repo" --json title,body,labels,state,url 2>/dev/null | \
        python3 -c "
import json, sys
d = json.load(sys.stdin)
print(f\"Title:  {d['title']}\")
print(f\"State:  {d['state']}\")
print(f\"URL:    {d['url']}\")
print(f\"Labels: {' '.join(l['name'] for l in d.get('labels',[]))}\")
print()
print(d.get('body','')[:2000])
" 2>/dev/null

    echo ""
    echo "── Linked PRs ──"
    gh pr list --repo "$gh_repo" --state open --search "issue:$num" \
        --json number,title,reviewDecision,url 2>/dev/null | \
        python3 -c "
import json, sys
prs = json.load(sys.stdin)
if not prs:
    print('(no linked PRs)')
for pr in prs:
    rd = pr.get('reviewDecision','') or 'open'
    print(f\"  PR #{pr['number']}: {pr['title']} ({rd})\")
    print(f\"  {pr['url']}\")
" 2>/dev/null

    echo ""
    echo "── Active Agent Sessions ──"
    local map_file2
    map_file2=$(_cached_session_map 2>/dev/null)
    if [[ -s "$map_file2" ]]; then
        python3 -c "
import json
m = json.load(open('$map_file2'))
key = '${repo}#${num}'
sessions = m.get(key, [])
if not sessions:
    print('(no active agent sessions)')
else:
    for s in sessions:
        print(f'  {s}')
" 2>/dev/null
        # Don't delete — _cached_session_map returns the shared cache file
    else
        echo "(no active agent sessions)"
    fi
}

# Interactive issue browser (fzf picker)
issue_browser() {
    local repo_filter="${1:-}" force_flag="${2:-}"

    # --all: show all repos
    if [[ "$repo_filter" == "--all" ]]; then
        repo_filter=""
    fi

    # --force: skip cache
    if [[ "$repo_filter" == "--force" ]]; then
        force_flag="--force"
        repo_filter=""
    elif [[ "$force_flag" == "--all" ]]; then
        repo_filter=""
        force_flag="--force"
    fi

    # No repo filter specified → auto-detect from CWD (skippable via TMS_NO_AUTO=1)
    if [[ -z "$repo_filter" && -z "${TMS_NO_AUTO:-}" ]]; then
        repo_filter=$(detect_repo_from_cwd)
        if [[ -n "$repo_filter" ]]; then
            echo "Auto-detected repo: $repo_filter (add --all for all repos)" >&2
        else
            echo "No repo detected from CWD; showing all repos" >&2
        fi
    fi

    # If for some reason --force wasn't set but passed, check
    if [[ "${2:-}" == "--force" ]]; then
        force_flag="--force"
    fi

    if ! command -v fzf &>/dev/null; then
        echo "fzf not found. Install with: apt install fzf"
        echo ""
        echo "Available issues:"
        issue_list "$repo_filter"
        exit 1
    fi

    if ! command -v tmq &>/dev/null; then
        echo "tmq not found (needed to dispatch issues)"
        exit 1
    fi

    # Build header with cache/repo info
    local fzf_header="enter:dispatch  ctrl-o:browser  ctrl-p:preview  ctrl-e:review  ctrl-s:sessions  ?:help  esc:cancel"
    if [[ "$force_flag" == "--force" ]]; then
        echo "Fetching issues (force refresh)..." >&2
    elif [[ -n "$repo_filter" ]]; then
        local cached="cached"
        _cache_valid "$repo_filter" || cached="fetching"
        echo "Issues for $repo_filter ($cached)..." >&2
    else
        echo "Fetching all issues..." >&2
    fi
    local issue_data
    issue_data=$(issue_list "$repo_filter" "$force_flag")

    # If no TTY, just print the list
    if [[ ! -t 0 ]]; then
        echo "$issue_data"
        return
    fi

    # Export for ctrl-r force-refresh reload; "--all" sentinel = all repos
    if [[ -z "$repo_filter" ]]; then
        export TMS_ISSUE_REPO="--all"
    else
        export TMS_ISSUE_REPO="$repo_filter"
    fi
    export TMS_ISSUE_FORCE="$force_flag"

    local selected
    stty -ixon 2>/dev/null  # enable ctrl+s passthrough
    selected=$(echo "$issue_data" | fzf \
        --header="$fzf_header" \
        --header-first \
        --ansi \
        --no-sort \
        --preview="tms --preview {}" \
        --preview-window='right:60%:wrap' \
        --bind="enter:accept" \
        --bind="ctrl-o:execute(gh issue view \$(echo {2} | tr -d '#') --web 2>/dev/null)" \
        --bind="ctrl-p:execute(tms --preview {} | less -R)" \
        --bind="ctrl-e:execute(repo={1}; iss=\$(echo {2} | tr -d '#'); pr=\$(gh pr list --repo bogocat/\$repo --search \"issue:\$iss\" --json number --jq '.[0].number' 2>/dev/null); if [[ -n \"\$pr\" ]]; then tmq review \$repo \$pr; else echo \"No linked PR found for \$repo#\$iss\"; fi)" \
        --bind="ctrl-s:reload(tms ls | tail -n +3)+change-header(sessions: enter=attach  ctrl-x/d=kill  ctrl-k=clean  ctrl-i=issues  ?=help)+change-preview(name=\"\$(echo {} | sed 's/.*\\t//')\"; tmux capture-pane -t \"\$name\" -p -S -40 2>/dev/null | sed 's/^/  /')" \
        --bind="?:execute(printf '%s\n\n' 'KEYBINDINGS' '-----------' 'enter      dispatch agent (via tmq)' 'ctrl-o     open issue in browser' 'ctrl-p     full preview' 'ctrl-e     code review linked PR' 'ctrl-s     back to sessions' 'ctrl-r     force refresh (skip cache)' '?          this help' 'esc        cancel' '' 'STATUS LEGEND (ST column)' '------------------------' '○ dim      open, no agent' '● cyan     active agent, no PR yet' '▶ blue     PR open, not reviewed' '◎ yellow   pending review' '✔ green    reviewed or ready to merge' '✗ red      blocked' '? magenta  question' | less -R)" \
        --bind="ctrl-r:reload(tms issues --raw \$TMS_ISSUE_REPO --force)+change-header(issues (refreshing...): enter=dispatch  ctrl-o=browser  ctrl-p=preview  ctrl-s=back  ?=help  esc=cancel)" \
        2>/dev/null || true)

    if [[ -n "$selected" ]]; then
        local col1 col2
        col1=$(echo "$selected" | awk '{print $1}')
        col2=$(echo "$selected" | awk '{print $2}' | tr -d '#')
        # Extract real session name from hidden tab field
        local real_name
        real_name=$(echo "$selected" | sed 's/.*\t//')
        # Smart enter: issues dispatch, sessions attach
        if is_known_repo "$col1"; then
            tmq "$col1" "$col2"
            exec tms
        else
            attach_session "$real_name"
            [[ -z "${TMUX:-}" ]] && exec tms
        fi
    fi
}

# ── clean: kill stale + compact ──────────────────────────────────

clean_stale() {
    local -a to_kill=()
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if is_session_stale "$name"; then
            to_kill+=("$name")
        fi
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null | sort)"

    if ((${#to_kill[@]} == 0)); then
        echo "No stale sessions found (>${STALE_DAYS}d, all windows idle)."
        return
    fi

    echo "Stale sessions (>${STALE_DAYS}d, all windows at shell prompt):"
    for s in "${to_kill[@]}"; do
        local wins
        wins=$(tmux list-sessions -F "#{session_windows}" -f "#{==:#{session_name},$s}" 2>/dev/null)
        local win_detail
        win_detail=$(tmux list-windows -t "$s" -F "#{window_index}:#{pane_current_command}" 2>/dev/null | tr '\n' ' ')
        echo "  $s  (${wins} windows: $win_detail)"
    done
    local auto_yes="${2:-}"
    if [[ "$auto_yes" != "--yes" ]]; then
        echo ""
        printf "Kill all %d? [y/N] " "${#to_kill[@]}"
        read -r ans
        if [[ ! "$ans" =~ ^[Yy]$ ]]; then
            echo "Cancelled."
            return
        fi
    fi

    for s in "${to_kill[@]}"; do
        tmux kill-session -t "$s" 2>/dev/null && echo "  killed $s" || echo "  failed $s"
    done

    # Offer compaction (skip prompt in --yes mode)
    if [[ "$auto_yes" != "--yes" ]]; then
        echo ""
        printf "Compact scratch session numbers (c0,c1,c2...)? [Y/n] "
        read -r ans2
        if [[ "$ans2" =~ ^[Nn]$ ]]; then
            return
        fi
    fi
    compact_scratch_sessions
}

# ── new: create a GitHub issue from the current repo ─────────────
# tms new [--repo <shortname>] [--title <title>] [--body <body>] [--label <label>]...
# Repo defaults to the cwd-detected repo. With no flags at all, prompts
# for title interactively and opens $EDITOR for the body. Otherwise flags
# are passed through to `gh issue create`.
#
# Always clears the issue cache afterwards so the new issue shows up
# in `tms issues` on the next refresh.

new_issue() {
    local repo_override="" title="" body="" labels=()
    local web=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)   repo_override="$2"; shift 2 ;;
            --title)  title="$2"; shift 2 ;;
            --body)   body="$2"; shift 2 ;;
            --label|--labels) labels+=("$2"); shift 2 ;;
            --web)    web=1; shift ;;
            -h|--help)
                cat <<'EOF'
tms new — create a GitHub issue in the current (or specified) repo

Usage:
  tms new [--repo <shortname>] [--title <title>] [--body <body>]
          [--label <label>]... [--web]

If --title is omitted, prompts for it.
If --body is omitted, $EDITOR is opened for the body (gh's default behavior).
The issue cache is cleared after creation so the new issue shows in
'tms issues' on the next refresh.

Repo defaults to the cwd-detected repo (see detect_repo_from_cwd).

Examples:
  tms new
  tms new --title "fix: race in foo" --body "Steps to reproduce..."
  tms new --repo distillery --label enhancement --label pipeline:book
EOF
                return ;;
            *) echo "tms new: unknown arg: $1" >&2; return 1 ;;
        esac
    done

    local repo
    if [[ -n "$repo_override" ]]; then
        repo="$repo_override"
    else
        repo=$(detect_repo_from_cwd)
    fi
    if [[ -z "$repo" ]]; then
        echo "tms new: could not detect repo from CWD; pass --repo" >&2
        return 1
    fi
    if ! is_known_repo "$repo"; then
        echo "tms new: unknown repo: $repo" >&2
        return 1
    fi

    local gh_repo
    gh_repo=$(_tmq_registry | awk -F'\t' -v s="$repo" '$1 == s {print $3; exit}')
    if [[ -z "$gh_repo" ]]; then
        echo "tms new: no GH slug for $repo" >&2
        return 1
    fi

    # Interactive title prompt if missing
    if [[ -z "$title" ]]; then
        printf "Title for %s issue: " "$repo"
        read -r title
        if [[ -z "$title" ]]; then
            echo "tms new: title required" >&2
            return 1
        fi
    fi

    # Build gh args. gh issue create semantics:
    #   --title X --body Y → non-interactive create (both required when stdin is not a TTY)
    #   --title X          → opens $EDITOR for body when stdin IS a TTY
    #   (nothing)          → prompts for title + opens editor for body
    # We pass --body when given, otherwise let gh open the editor.
    # We never need to pass an --editor flag to gh.
    local -a gh_args=(issue create --repo "$gh_repo" --title "$title")
    if [[ -n "$body" ]]; then
        gh_args+=(--body "$body")
    fi
    for lab in "${labels[@]}"; do
        gh_args+=(--label "$lab")
    done
    (( web )) && gh_args+=(--web)

    echo "Creating issue in $gh_repo: $title" >&2
    gh "${gh_args[@]}"
    local rc=$?

    # Always clear the cache so the new issue shows in tms issues
    _clear_cache 2>/dev/null || true
    return $rc
}

# ── import: wrap a legacy c/o/p scratch session as an aoe session ─
# tms import <scratch-session> <repo> <issue-number> [--kill-original]
#
# Reads the legacy session's cwd + agent, then creates a new aoe session
# at the same cwd with the same tool, titled feat-<repo>#<num>. After it
# comes up the user can attach to the new session and kill the original.
# With --kill-original, kills the legacy session non-interactively.

import_session() {
    local session_name="" repo="" issue_num="" kill_orig=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kill-original) kill_orig=1; shift ;;
            -h|--help)
                cat <<'EOF'
tms import — wrap a legacy scratch session as an aoe-managed session

Usage:
  tms import <session-name> <repo> <issue-number> [--kill-original]

Reads <session-name>'s cwd and current agent, then creates a new aoe
session at the same cwd with the same tool, titled feat-<repo>#<num>.
Useful for c/o/p scratch sessions that turned out to be real work on
a specific issue and should be tracked in the aoe dashboard.

After the new session comes up, with --kill-original the script also
kills the legacy session non-interactively. Without it, the original
is left running for the user to inspect and clean up manually.

Examples:
  tms import c5 distillery 245
  tms import o2 home-portal 92 --kill-original
EOF
                return ;;
            *)
                if [[ -z "$session_name" ]]; then session_name="$1"
                elif [[ -z "$repo" ]];       then repo="$1"
                elif [[ -z "$issue_num" ]];  then issue_num="$1"
                fi
                shift ;;
        esac
    done

    if [[ -z "$session_name" || -z "$repo" || -z "$issue_num" ]]; then
        echo "tms import: usage: tms import <session> <repo> <num> [--kill-original]" >&2
        return 1
    fi
    if ! is_known_repo "$repo"; then
        echo "tms import: unknown repo: $repo" >&2
        return 1
    fi
    if ! [[ "$issue_num" =~ ^[0-9]+$ ]]; then
        echo "tms import: invalid issue number: $issue_num" >&2
        return 1
    fi

    # Look up the legacy session
    local cwd cmd agent_tool
    cwd=$(tmux list-panes -t "$session_name" -F "#{pane_current_path}" 2>/dev/null | head -1) || {
        echo "tms import: session not found: $session_name" >&2
        return 1
    }
    cmd=$(tmux list-panes -t "$session_name" -F "#{pane_current_command}" 2>/dev/null | head -1)
    case "$cmd" in
        pi)        agent_tool="pi" ;;
        claude)    agent_tool="claude" ;;
        opencode)  agent_tool="opencode" ;;
        codex)     agent_tool="codex" ;;
        *)
            echo "tms import: legacy session isn't running a known agent (cmd=$cmd)" >&2
            echo "  import manually with: aoe add \"$cwd\" -t feat-$repo#$issue_num --tool <name>" >&2
            return 1
            ;;
    esac

    if [[ -z "$cwd" ]]; then
        echo "tms import: could not read cwd of $session_name" >&2
        return 1
    fi

    # Verify the cwd belongs to the target repo (warn if it doesn't)
    local cwd_repo
    cwd_repo=$(detect_repo_from_cwd "$cwd")
    if [[ -n "$cwd_repo" && "$cwd_repo" != "$repo" ]]; then
        echo "tms import: warning — cwd $cwd maps to repo '$cwd_repo', not '$repo'" >&2
        printf "Continue anyway? [y/N] "
        read -r ans
        [[ "$ans" =~ ^[Yy]$ ]] || return 1
    fi

    # Verify the issue exists (cheaper than a typo'd import)
    local gh_repo
    gh_repo=$(_tmq_registry | awk -F'\t' -v s="$repo" '$1 == s {print $3; exit}')
    if ! gh issue view "$issue_num" --repo "$gh_repo" --json number >/dev/null 2>&1; then
        echo "tms import: $gh_repo#$issue_num not found" >&2
        return 1
    fi

    local title="feat-$repo#$issue_num"
    echo "Importing $session_name → $title ($agent_tool in $cwd)" >&2
    # No -l/--launch: aoe add's auto-attach fails in non-tty contexts.
    # We start the session explicitly with `aoe session start` instead.
    local aoe_err
    aoe_err=$(aoe add "$cwd" --title "$title" --tool "$agent_tool" --trust-hooks 2>&1 1>/dev/null) || {
        echo "tms import: aoe add failed: ${aoe_err:-no stderr}" >&2
        return 1
    }
    aoe_err=$(aoe session start "$title" 2>&1 1>/dev/null) || {
        echo "tms import: aoe add succeeded but session start failed: ${aoe_err:-no stderr}" >&2
        echo "  start it manually with: aoe session start $title" >&2
        return 1
    }
    local aoe_id
    aoe_id=$(aoe session show "$title" --json 2>/dev/null | python3 -c 'import json,sys; print(json.load(sys.stdin)["id"][:8])' 2>/dev/null || echo '?')
    echo "  added + started $title (aoe id: $aoe_id)" >&2

    if (( kill_orig )); then
        echo "Killing original session $session_name" >&2
        tmux kill-session -t "$session_name" 2>/dev/null && echo "  killed $session_name" \
            || echo "  failed to kill $session_name"
    else
        echo "" >&2
        echo "Original session $session_name is still running. To clean up:" >&2
        echo "  tms kill $session_name" >&2
        echo "Or re-run with --kill-original." >&2
    fi
}


# Shared router for top-level flags that forward to \`tms issues\`.
_route_issues_top() {
    local args=()
    case "$1" in
        --view)
            shift
            local view="${1:-all}"
            shift
            local repo=$(detect_repo_from_cwd)
            issue_browser "$repo" "" "$view"
            ;;
        --clear-cache)
            _clear_cache
            echo "Issue cache cleared."
            ;;
        --new)
            shift
            new_issue "$@"
            ;;
        --import)
            shift
            import_session "$@"
            ;;
    esac
}

# ── main ─────────────────────────────────────────────────────────

case "${1:-}" in
    ls|list)
        session_list
        ;;
    kill)
        if [[ -z "${2:-}" ]]; then
            echo "Usage: tms kill <session-name>"
            exit 1
        fi
        kill_session "$2" "${3:-}"
        ;;
    rename)
        if [[ -z "${2:-}" ]]; then
            echo "Usage: tms rename <session-name>"
            exit 1
        fi
        rename_session "$2"
        ;;
    stale)
        stale_sessions
        ;;
    clean)
        clean_stale "$@"
        ;;
    compact)
        compact_scratch_sessions
        ;;
    sessions|session)
        # Secondary: session browser (use aoe for live monitoring)
        if ! command -v fzf &>/dev/null; then
            echo "fzf not found. Install with: apt install fzf" >&2
            session_list
            return 1
        fi
        stty -ixon 2>/dev/null
        local selected
        selected=$(session_list | fzf \
            --header='enter:attach  ctrl-x/d:kill  ctrl-r:rename  ctrl-k:clean  ctrl-p:peek  ctrl-i:issues  ?:help  esc:cancel' \
            --header-first --ansi --no-sort \
            --preview='name=$(echo {} | sed "s/.*\t//"); tmux capture-pane -t "$name" -p -S -40 2>/dev/null | sed "s/^/  /"' \
            --preview-window='right:60%:wrap' \
            --bind="enter:accept" \
            --bind="ctrl-x:execute(real=\$(echo {} | sed 's/.*\t//'); tms kill \$real --force)+reload(tms ls | tail -n +3)" \
            --bind="ctrl-d:execute(real=\$(echo {} | sed 's/.*\t//'); tms kill \$real --force)+reload(tms ls | tail -n +3)" \
            --bind="ctrl-r:become(stty sane; real=\$(echo {} | sed 's/.*\t//'); tms rename \$real; exec tms)" \
            --bind="ctrl-p:execute(real=\$(echo {} | sed 's/.*\t//'); tmux capture-pane -t \"\$real\" -p -S -40 | less -R)" \
            --bind="ctrl-k:execute(tms clean --yes)+reload(tms ls | tail -n +3)" \
            --bind="ctrl-i:reload(tms issues --raw --all)+change-header(issues: enter=dispatch  ctrl-o=browser  ctrl-p=preview  ctrl-s=back  ?=help  esc=cancel)+change-preview(tms --preview {})" \
            --bind="ctrl-s:reload(tms ls | tail -n +3)+change-header(enter:attach  ctrl-x/d=kill  ctrl-r:rename  ctrl-k=clean  ctrl-p=peek  ctrl-i=issues  ?:help  esc=cancel)+change-preview(name=\"\$(echo {} | sed 's/.*\\t//')\"; tmux capture-pane -t \"\$name\" -p -S -40 2>/dev/null | sed 's/^/  /')" \
            --bind="?:execute(printf '%s\n\n' 'KEYBINDINGS' '-----------' 'enter      attach' 'ctrl-x/d   kill session' 'ctrl-r     rename' 'ctrl-k     clean stale' 'ctrl-i     switch to issues' 'ctrl-s     back to sessions' 'ctrl-p     peek terminal' '?          help' 'esc        cancel' | less -R)" \
            --tac) || true
        if [[ -n "$selected" ]]; then
            local col1 col2 real_name
            col1=$(echo "$selected" | awk '{print $1}')
            col2=$(echo "$selected" | awk '{print $2}' | tr -d '#')
            real_name=$(echo "$selected" | sed 's/.*\t//')
            if is_known_repo "$col1"; then
                tmq "$col1" "$col2"
                exec tms
            else
                attach_session "$real_name"
                [[ -z "${TMUX:-}" ]] && exec tms
            fi
        fi
        ;;
    new)
        shift
        new_issue "$@"
        ;;
    import)
        shift
        import_session "$@"
        ;;
    events)
        # tms events — fleet dispatch metrics (issue #53) + independent
        # review poller (issue #57). Subcommands:
        #   transitions  poll aoe + tmux for state changes
        #   stats        compute and print aggregate report
        #   scan-reviews poll open PRs lacking a reviewer verdict (#57)
        case "${2:-}" in
            transitions)
                PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
                    python3 -m tms.events transitions
                ;;
            stats)
                shift 2
                PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
                    python3 -m tms.events stats "$@"
                ;;
            scan-reviews)
                # Independent review poller (tms#57 Phase 2). Default is a
                # read-only dry run; --dispatch spawns `tmq review` for PRs
                # with no verdict (capped by --max-dispatch, default 3).
                shift 2
                PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib" \
                    python3 -m tms.review_poll scan-reviews "$@"
                ;;
            -h|--help)
                cat <<'EOF'
tms events — fleet dispatch metrics (issue #53) + review poller (#57)

Usage:
  tms events transitions     poll aoe + tmux panes, emit transition events
  tms events stats            compute and print aggregate metrics report
  tms events scan-reviews     list open PRs lacking a reviewer verdict (#57)

Stats options:
  --since YYYY-MM-DD         filter events from this date onward
  --json                     output as JSON (machine-readable)
  --by-label                 per-label breakdown (merge/block rates, latency)
  --by-area                  per-area breakdown (from area:* labels)
  --by-point                 per-point-estimate breakdown (from point:N labels)
  --by-blocked-class         BLOCKED events by taxonomy class (#76)

Scan-reviews options (tms#57):
  --dispatch                 spawn `tmq review` for PRs needing review
                             (default: dry run, no dispatch)
  --max-dispatch <n>         cap dispatches per run (default 3; 0 = scan-only)
  --repo <short>             restrict scan to one registered repo

See docs/events-format.md for the event log schema.
EOF
                ;;
            *)
                echo "tms events: unknown subcommand '${2:-}'" >&2
                echo "Usage: tms events <transitions|stats|scan-reviews>" >&2
                exit 1
                ;;
        esac
        ;;
    wraps)
        # tms wraps — wrap-on-terminal hook (issue #82).
        # Subcommand:
        #   scan-wraps  poll for new terminal transitions, dispatch objective wraps
        case "${2:-}" in
            scan-wraps)
                shift 2
                PYTHONPATH="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"/../lib \
                    python3 -m tms.wrap_on_terminal scan-wraps "$@"
                ;;
            -h|--help)
                cat <<'EOF'
tms wraps — wrap-on-terminal hook (issue #82)

Usage:
  tms wraps scan-wraps     scan for new terminal transitions, dispatch wraps

Options:
  --dispatch               write memory files + post issue comments
                           (default: dry run, no side effects)
  --dry-run                synthesize wraps without writing (for testing)

Objective wrap: when an agent session reaches terminal state,
synthesize a session wrap from objective sources only (events, gh,
llm_call_log) — no conversation data. Output is a memory file at
~/.claude/projects/-root/memory/issue-wrap-<repo>#<issue>.md and a
closing comment on the GitHub issue.
EOF
                ;;
            *)
                echo "tms wraps: unknown subcommand '${2:-}'" >&2
                echo "Usage: tms wraps scan-wraps" >&2
                exit 1
                ;;
        esac
        ;;
    issues)
        if [[ "${2:-}" == "--raw" ]]; then
            raw_repo="${3:-}"
            raw_force="${4:-}"
            if [[ -z "$raw_repo" ]]; then
                raw_repo=$(detect_repo_from_cwd)
                [[ -n "$raw_repo" ]] && echo "repo:$raw_repo (add --all for all)" >&2
            elif [[ "$raw_repo" == "--all" ]]; then
                raw_repo=""
            fi
            if [[ "$raw_repo" == "--force" ]]; then
                raw_force="--force"; raw_repo=""
            fi
            issue_list "$raw_repo" "$raw_force"
            exit 0
        fi
        if [[ "${2:-}" == "--clear-cache" ]]; then
            _clear_cache
            echo "Issue cache cleared."
            exit 0
        fi
        issue_browser "${2:-}" "${3:-}"
        ;;
    "")
        # DEFAULT: issue browser. The user mainly uses tms to
        # dispatch agents on GitHub issues; aoe handles live
        # session monitoring. `tms sessions` opens the session
        # browser when needed.
        issue_browser
        ;;
    --all)
        # Top-level: force all repos (skip CWD auto-detect)
        export TMS_NO_AUTO=1
        issue_browser --all
        ;;
    --raw|--raw=*)
        # Top-level: \`tms --raw [repo|--all] [--force]\`
        shift
        raw_repo=""
        raw_force=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --all) raw_repo="--all"; shift ;;
                --force) raw_force="--force"; shift ;;
                *) [[ -z "$raw_repo" ]] && raw_repo="$1"; shift ;;
            esac
        done
        [[ "$raw_repo" == "--all" ]] && raw_repo=""
        [[ -z "$raw_repo" ]] && { detected=$(detect_repo_from_cwd); [[ -n "$detected" ]] && raw_repo="$detected"; }
        issue_list "$raw_repo" "$raw_force"
        ;;
    --force)
        # Top-level: skip cache, default repo
        shift
        forced_repo=$(detect_repo_from_cwd)
        issue_list "$forced_repo" --force
        ;;
    --view|--clear-cache|--new|--import)
        # Forward to the issues subcommand
        _route_issues_top "$@"
        ;;
    --preview)
        issue_preview "${2:-}"
        ;;
    *)
        # Unknown first arg: if it looks like a known repo shortname,
        # forward to \`tms issues <repo>\`. Otherwise show usage.
        if is_known_repo "$1"; then
            issue_browser "$1"
        else
            echo "Usage: tms [ls|kill <name>|rename <name>|stale|clean|compact|issues [repo|--all|--force]|issues --clear-cache|new|import|<repo>]"
            echo "       tms --all | --raw | --view <mode> | --force"
            exit 1
        fi
        ;;
esac
