#!/usr/bin/env bash
# tms — GitHub issue browser + tmux session manager
#
# Primary use: browse + dispatch agents on issues. Sessions are
# second-class; use aoe for live session monitoring.
#
# Usage:
#   tms                              issue browser (default)
#   tms sessions                     session browser
#   tms issues [repo|--all]          open issue browser directly
#          --all       show all repos
#          --force     skip cache (5-min TTL)
#          --raw       just print rows, no fzf
#          --clear-cache
#   tms ls                           list sessions
#   tms kill <name>                  kill session
#   tms rename <name>                rename session
#   tms clean                        kill stale + compact scratch
#   tms stale                        list idle >7d
#   tms compact                      renumber c*/o*/p* scratch
#   tms --preview <row>              render preview pane (internal)
#
# Keybindings in issue browser (fzf):
#   enter        dispatch agent on issue (via tmq)
#   ctrl-o       open issue in browser
#   ctrl-p       full preview
#   ctrl-e       code review linked PR (if any)
#   ctrl-v       cycle view: All / Active / Yours / Stale
#   ctrl-r       force refresh (skip cache)
#   ctrl-s       jump to session browser
#   ?            help
#   esc          cancel

set -euo pipefail

STALE_DAYS=7
NOW=$(date +%s)
ISSUE_CACHE_DIR=/tmp/tms-issues-cache
ISSUE_CACHE_TTL=300      # 5 min — issues don't change fast
SESSION_MAP_TTL=15       # 15s — sessions move quickly

# GH login (cached per-invocation)
GH_USER="${TMS_GH_USER:-}"
if [[ -z "$GH_USER" ]] && command -v gh &>/dev/null; then
    GH_USER=$(gh api user --jq '.login' 2>/dev/null || echo "")
fi
export GH_USER

# ── repo registry (mirrors tmq) ──────────────────────────────────

issue_repos() {
    cat <<'EOF'
distillery:bogocat/distillery
home-portal:bogocat/home-portal
tower-fleet:bogocat/tower-fleet
scripts:bogocat/scripts
palimpsest:bogocat/palimpsest
rms:bogocat/openrms
tms:bogocat/tms
EOF
}

# Detect repo from cwd (handles worktrees too)
detect_repo_from_cwd() {
    local dir="${1:-$PWD}"
    case "$dir" in
        */distillery*|*/wt-distillery*/) echo distillery ;;
        */home-portal*|*/wt-home-portal*/) echo home-portal ;;
        */tower-fleet*|*/wt-tower-fleet*/)  echo tower-fleet ;;
        */scripts*|*/wt-scripts*/|*/bogocat/scripts*) echo scripts ;;
        */palimpsest*|*/wt-palimpsest*/)    echo palimpsest ;;
        */rms*|*/wt-rms*/)                echo rms ;;
        */tms*)                           echo tms ;;
        *)                                echo "" ;;
    esac
}

# ── issue fetching (parallel, all states) ────────────────────────

_cache_file() { echo "$ISSUE_CACHE_DIR/$1.ndjson"; }
_cache_valid() {
    local cf
    cf=$(_cache_file "$1")
    [[ -f "$cf" ]] || return 1
    local age
    age=$(($(date +%s) - $(stat -c %Y "$cf" 2>/dev/null || echo 0)))
    (( age < ISSUE_CACHE_TTL ))
}
_write_cache() { mkdir -p "$ISSUE_CACHE_DIR"; cat - > "$(_cache_file "$1")"; }
_clear_cache() { rm -rf "$ISSUE_CACHE_DIR"; mkdir -p "$ISSUE_CACHE_DIR"; }

# Fetch a single repo: open + closed issues, open PRs. NDJSON out.
_fetch_repo() {
    local short=$1 gh_repo=$2

    # All issues (open + closed); stateReason fetched in preview only (not
    # available via `gh issue list --json`).
    gh issue list --repo "$gh_repo" --state all --limit 100 \
        --json number,title,state,labels,url,createdAt,updatedAt,closedAt,assignees 2>/dev/null \
    | python3 -c "
import json, sys
for iss in json.load(sys.stdin):
    print(json.dumps({
        'n': iss['number'],
        't': iss['title'],
        's': iss['state'],                  # OPEN | CLOSED
        'l': ' '.join(x['name'] for x in iss.get('labels', [])),
        'u': iss.get('url',''),
        'c': iss.get('createdAt',''),
        'U': iss.get('updatedAt',''),
        'C': iss.get('closedAt',''),
        'a': [x.get('login','') for x in iss.get('assignees', [])],
    }))
"

    # Open PRs — for status (review state, draft, etc.)
    gh pr list --repo "$gh_repo" --state open --limit 100 \
        --json number,title,headRefName,reviewDecision,isDraft,url 2>/dev/null \
    | python3 -c "
import json, sys, re
for pr in json.load(sys.stdin):
    # Find which issue this PR closes
    m = re.search(r'issue-(\d+)', pr.get('headRefName',''))
    issue_num = int(m.group(1)) if m else None
    rd = pr.get('reviewDecision') or ''
    draft = pr.get('isDraft', False)
    state = 'draft' if draft else (
        'ready-to-merge' if rd == 'APPROVED' else
        'changes-requested' if rd == 'CHANGES_REQUESTED' else
        'pending-review' if rd == 'REVIEW_REQUIRED' else
        'in-progress'
    )
    print(json.dumps({
        'kind': 'pr',
        'pr': pr['number'],
        'iss': issue_num,
        's': state,
        't': pr['title'],
        'u': pr.get('url',''),
    }))
"

    # Recently closed/merged PRs — for "merged" status on closed issues
    gh pr list --repo "$gh_repo" --state closed --limit 50 \
        --json number,state,mergedAt,headRefName 2>/dev/null \
    | python3 -c "
import json, sys, re
for pr in json.load(sys.stdin):
    m = re.search(r'issue-(\d+)', pr.get('headRefName',''))
    issue_num = int(m.group(1)) if m else None
    print(json.dumps({
        'kind': 'closed-pr',
        'pr': pr['number'],
        'iss': issue_num,
        's': pr.get('state',''),    # MERGED | CLOSED
        'm': pr.get('mergedAt',''),
    }))
"
}

# Fetch all repos in parallel; emit merged NDJSON, then write per-repo cache.
fetch_all_issues() {
    local filter="${1:-}" force="${2:-}"

    mkdir -p "$ISSUE_CACHE_DIR"
    local -a pids=()
    local -a outfiles=()
    local -a repos_fetched=()

    while IFS=: read -r short gh_repo; do
        [[ -n "$filter" && "$short" != "$filter" ]] && continue
        if [[ "$force" != "--force" ]] && _cache_valid "$short"; then
            cat "$(_cache_file "$short")"
            continue
        fi
        local out="/tmp/tms-fetch-$short-$$.ndjson"
        outfiles+=("$out")
        repos_fetched+=("$short")
        ( _fetch_repo "$short" "$gh_repo" | python3 -c "
import json, sys
short = '$short'
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    d = json.loads(line)
    d['repo'] = short
    print(json.dumps(d))
" > "$out" 2>/dev/null ) &
        pids+=($!)
    done <<< "$(issue_repos)"

    # Wait for parallel fetches
    for pid in "${pids[@]}"; do wait "$pid" 2>/dev/null || true; done

    # Emit merged stream to stdout
    local merged="/tmp/tms-fetch-merged-$$.ndjson"
    : > "$merged"
    for f in "${outfiles[@]}"; do
        [[ -s "$f" ]] && cat "$f" >> "$merged"
        rm -f "$f"
    done
    cat "$merged"

    # Write per-repo cache from merged stream
    python3 - "$merged" "$ISSUE_CACHE_DIR" "${repos_fetched[@]}" << 'PYEOF' 2>/dev/null || true
import sys, os, json
from collections import defaultdict
merged = sys.argv[1]
cache_dir = sys.argv[2]
repos = sys.argv[3:]
out = defaultdict(list)
with open(merged) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try: d = json.loads(line)
        except Exception: continue
        r = d.get('repo','')
        if r: out[r].append(line)
for r in repos:
    if r in out:
        with open(os.path.join(cache_dir, f'{r}.ndjson'), 'w') as f:
            f.write('\n'.join(out[r]) + '\n')
PYEOF
    rm -f "$merged"
}

# ── session map (which issues have live agents) ──────────────────

_issue_session_map() {
    local tmp="/tmp/tms-session-map-$$.json"
    python3 - "$tmp" << 'PYEOF'
import json, subprocess, re, os, sys

ICONS = {'pi': 'π', 'claude': 'cc', 'opencode': 'oc', 'python3': 'py', 'bash': 'sh', 'zsh': 'sh'}
REPOS = ['home-portal', 'distillery', 'tower-fleet', 'scripts', 'palimpsest', 'rms', 'deploy', 'tms']

def shell(cmd, timeout=5):
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip()
    except Exception:
        return ''

panes_raw = shell(['tmux', 'list-panes', '-a', '-F', '#{session_name}|#{pane_current_command}|#{pane_current_path}'])
ses_info = {}
for line in panes_raw.split('\n'):
    if '|' in line:
        p = line.split('|', 2)
        ses_info.setdefault(p[0], (p[1], p[2]))

aoe_data = {}
try:
    for s in json.loads(shell(['aoe', 'list', '--json'], timeout=3)):
        aoe_data[s['title']] = {'tool': s.get('tool',''),
                                'branch': (s.get('worktree') or {}).get('branch',''),
                                'path': s.get('path','')}
except Exception:
    pass

mapping = {}
for session, (cmd, cwd) in ses_info.items():
    icon = ICONS.get(cmd, cmd[:3] if cmd else '?')

    # tmq: feat-<repo>#<num>[-cc|-oc]
    m = re.match(r'(feat|fix|chore|review)-(.+?)#(\d+)(-cc|-oc)?$', session)
    if m:
        key = f'{m.group(2)}#{m.group(3)}'
        mapping.setdefault(key, []).append(f'{session} {icon}')
        continue

    # aoe: aoe_<title>_<uuid>
    if session.startswith('aoe_'):
        parts = session.split('_')
        if len(parts) >= 3:
            title = '_'.join(parts[1:-1])
            info = aoe_data.get(title, {})
            path = info.get('path', '')
            branch = info.get('branch', '')
            repo_name = ''
            num = ''
            bm = re.match(r'(feat|fix|chore|review)/issue-(\d+)', branch)
            if bm:
                num = bm.group(2)
                for r in REPOS:
                    if f'/{r}' in path or path.endswith(f'/{r}'):
                        repo_name = r; break
            if not num:
                bm = re.match(r'(feat|fix|chore|review)-(.+?)#(\d+)', title.replace('_', '#'))
                if bm:
                    num = bm.group(3); repo_name = bm.group(2)
            if num and repo_name:
                mapping.setdefault(f'{repo_name}#{num}', []).append(f'{session} {icon}')
        continue

    # scratch: c<n>, o<n>, p<n> — resolve via cwd + branch
    m = re.match(r'^([cop])(\d+)$', session)
    if not m:
        continue
    if not cwd or not os.path.isdir(os.path.join(cwd, '.git')):
        continue
    branch = shell(['git', '-C', cwd, 'branch', '--show-current'])
    bm = re.match(r'(feat|fix|chore|review)/issue-(\d+)', branch)
    if not bm:
        continue
    num = bm.group(2)
    repo_name = os.path.basename(cwd.rstrip('/'))
    for r in REPOS:
        if cwd.endswith(f'/{r}') or f'/{r}-worktrees/' in cwd or f'/{r}/' in cwd:
            repo_name = r; break
    mapping.setdefault(f'{repo_name}#{num}', []).append(f'{session} {icon}')

with open(sys.argv[1], 'w') as f:
    json.dump(mapping, f)
PYEOF
    echo "$tmp"
}

_cached_session_map() {
    local cache_file="/tmp/tms-session-map-cache.json"
    if [[ -f "$cache_file" ]]; then
        local age=$(($(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || echo 0)))
        if (( age < SESSION_MAP_TTL )); then
            echo "$cache_file"; return
        fi
    fi
    local map_file
    map_file=$(_issue_session_map)
    cp "$map_file" "$cache_file"
    rm -f "$map_file"
    echo "$cache_file"
}

# ── formatting helpers ──────────────────────────────────────────

human_age() {
    # input: ISO 8601 timestamp; output: relative age (5m / 2h / 3d / 2w / 5mo / 1y)
    local iso=$1 now=${2:-$NOW}
    [[ -z "$iso" || "$iso" == "null" ]] && { echo "—"; return; }
    local ts
    ts=$(date -d "$iso" +%s 2>/dev/null) || { echo "—"; return; }
    local diff=$(( now - ts ))
    (( diff < 0 )) && diff=0
    if   (( diff < 60 ));       then echo "${diff}s"
    elif (( diff < 3600 ));     then echo "$((diff / 60))m"
    elif (( diff < 86400 ));    then echo "$((diff / 3600))h"
    elif (( diff < 604800 ));   then echo "$((diff / 86400))d"
    elif (( diff < 2592000 ));  then echo "$((diff / 604800))w"
    elif (( diff < 31536000 )); then echo "$((diff / 2592000))mo"
    else                             echo "$((diff / 31536000))y"
    fi
}

# ── enrich + format issues for display ───────────────────────────

# view: all | active | yours | stale
# Output: tab-separated lines, parseable for fzf
#   visible: REPO  #NN  ST  STATUS  AGENT  AGE  UPD  ★  TITLE
#   hidden:  <repo>#<num>  (tab-separated, used for dispatch on enter)
issue_list() {
    local view="${1:-all}" repo_filter="${2:-}" force_flag="${3:-}"
    local map_file
    map_file=$(_cached_session_map 2>/dev/null || echo "")

    local ndjson
    ndjson=$(fetch_all_issues "$repo_filter" "$force_flag")

    # Write to a temp file so we can pre-process (assign repo to PRs) in one
    # pass, then format in a second pass. Necessary because the fetch wrapper
    # already tags lines with repo.
    local tmp
    tmp=$(mktemp /tmp/tms-fmt-XXXXXX.ndjson)
    echo "$ndjson" > "$tmp"

    # Single Python: enrich + format + sort, all in one process
    python3 - "$view" "$map_file" "$GH_USER" "$NOW" "$tmp" << 'PYEOF'
import json, sys, os
from datetime import datetime

view = sys.argv[1]
map_file = sys.argv[2]
gh_user = sys.argv[3]
now = int(sys.argv[4])
tmp = sys.argv[5]

R='\033[31m'; G='\033[32m'; Y='\033[33m'; B='\033[34m'
M='\033[35m'; C='\033[36m'; W='\033[37m'; D='\033[2m'; N='\033[0m'; BOLD='\033[1m'
def color(c, s): return f'{c}{s}{N}'

def parse_ts(s):
    if not s or s == 'null': return 0
    try: return int(datetime.fromisoformat(s.replace('Z','+00:00')).timestamp())
    except Exception: return 0

def human_age(ts):
    if ts == 0: return '—'
    diff = max(0, now - ts)
    if   diff < 60:       return f'{diff}s'
    elif diff < 3600:     return f'{diff // 60}m'
    elif diff < 86400:    return f'{diff // 3600}h'
    elif diff < 604800:   return f'{diff // 86400}d'
    elif diff < 2592000:  return f'{diff // 604800}w'
    elif diff < 31536000: return f'{diff // 2592000}mo'
    else:                 return f'{diff // 31536000}y'

# Load session map
sessions = {}
if map_file and os.path.exists(map_file):
    try: sessions = json.load(open(map_file))
    except Exception: pass

# Read all lines; separate issues vs prs
issues = {}   # key (repo,n) -> dict
prs = {}      # key (repo, iss_n) -> dict

with open(tmp) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try: d = json.loads(line)
        except Exception: continue

        if d.get('kind') == 'pr':
            iss = d.get('iss')
            repo = d.get('repo','')
            if iss is not None and repo:
                prs[(repo, iss)] = d
            continue
        if d.get('kind') == 'closed-pr':
            iss = d.get('iss')
            repo = d.get('repo','')
            if iss is not None and repo:
                # Only set if not already (closed-pr is fallback for issues we don't have PR info for)
                prs.setdefault((repo, iss), d)
            continue

        repo = d.get('repo','')
        n = d.get('n')
        if not repo or n is None: continue
        issues[(repo, n)] = {
            'repo': repo, 'n': n, 't': d.get('t',''),
            'state': d.get('s','OPEN'),
            'labels': (d.get('l') or '').lower(),
            'url': d.get('u',''),
            'created': parse_ts(d.get('c','')),
            'updated': parse_ts(d.get('U','')),
            'closed': parse_ts(d.get('C','')),
            'assignees': d.get('a',[]) or [],
        }

# Derive status for each issue
def derive_status(iss, pr):
    state = iss['state']
    labels = iss['labels']
    key = f'{iss["repo"]}#{iss["n"]}'
    has_agent = bool(sessions.get(key))

    # Label overrides
    if 'blocked' in labels:
        return ('✗', 'blocked', R)
    if 'question' in labels:
        return ('?', 'question', M)
    if 'reviewed' in labels:
        return ('✔', 'reviewed', G)

    if state == 'OPEN':
        # Open issue: derive from PR
        if pr and pr.get('kind') == 'pr':
            s = pr.get('s','')
            if s == 'ready-to-merge':   return ('✓', 'ready', G)
            if s == 'changes-requested': return ('✎', 'changes', R)
            if s == 'pending-review':   return ('◎', 'review', Y)
            if s == 'draft':            return ('◐', 'draft', D)
            if s == 'in-progress':      return ('▶', 'pr open', B)
        if has_agent:
            return ('●', 'active', C + BOLD)
        return ('○', 'open', D)

    # CLOSED
    if pr and pr.get('s') == 'MERGED':
        return ('✓', 'merged', G + D)   # dim
    if pr and pr.get('s') == 'CLOSED':
        return ('✕', 'closed', R + D)   # dim
    return ('✕', 'closed', R + D)

# Build rows + apply view filter
rows = []
STALE_SECS = 14 * 86400
RECENT_CLOSED_SECS = 14 * 86400

for (repo, n), iss in issues.items():
    key = f'{repo}#{n}'
    pr = prs.get((repo, n))
    sym, status_text, color_code = derive_status(iss, pr)
    agents = sessions.get(key, [])

    is_open = iss['state'] == 'OPEN'
    is_recently_closed = (not is_open) and iss['closed'] > 0 and (now - iss['closed']) < RECENT_CLOSED_SECS
    has_agent = bool(agents)
    is_yours = bool(gh_user) and (gh_user in iss['assignees'])
    is_stale = (is_open
                and not has_agent
                and iss['updated'] > 0
                and (now - iss['updated']) > STALE_SECS
                and (now - iss['created']) > STALE_SECS)

    # View filter
    if view == 'active' and not has_agent: continue
    if view == 'yours' and not is_yours: continue
    if view == 'stale' and not is_stale: continue
    # 'all' shows: open + recently closed; older closed filtered out
    if view == 'all' and not is_open and not is_recently_closed: continue

    rows.append({
        'repo': repo, 'n': n, 'title': iss['t'],
        'sym': sym, 'status': status_text, 'color': color_code,
        'agents': agents, 'is_open': is_open,
        'created': iss['created'], 'updated': iss['updated'], 'closed': iss['closed'],
        'is_yours': is_yours,
        'sort_key': (0 if is_open else 1, -(iss['updated'] if is_open else iss['closed'])),
    })

# Sort: open by updated desc, closed by closed desc, then by repo/n
rows.sort(key=lambda r: (r['sort_key'][0], r['sort_key'][1], r['repo'], r['n']))

# Format
def agent_icons(agts):
    if not agts: return ''
    icons = []
    for s in agts:
        parts = s.rsplit(' ', 1)
        icons.append(parts[1] if len(parts) == 2 else s)
    return ' '.join(icons[:3])

header = f"{'REPO':<12} {'#':<5} {'ST':<3} {'STATUS':<10} {'AGENT':<7} {'AGE':<5} {'UPD':<5} {'★':<2} TITLE"
print(header)
print('─' * 78)

count_open = sum(1 for r in rows if r['is_open'])
count_closed = sum(1 for r in rows if not r['is_open'])

for r in rows:
    sym_c = color(r['color'], r['sym'])
    status_c = color(r['color'], f"{r['status']:<9}")
    age = human_age(r['created'])
    upd = human_age(r['updated']) if r['is_open'] else human_age(r['closed'])
    star = '★' if r['is_yours'] else ' '
    star_c = color(Y + BOLD, star) if r['is_yours'] else ' '
    agents = agent_icons(r['agents'])
    agents_c = color(C + BOLD, f'{agents:<6}') if agents else color(D, '—'.ljust(6))
    title = r['title']
    if r['sym'] in ('○', '◐') and not r['is_yours']:
        title = color(D, title)
    if not r['is_open']:
        title = color(D, title)

    line = f"{r['repo']:<12} #{r['n']:<4} {sym_c} {status_c} {agents_c} {age:<5} {upd:<5} {star_c} {title}"
    # Hidden tab field: <repo>#<num> for fzf to extract on enter
    print(f"{line}\t{r['repo']}#{r['n']}")
PYEOF
    rm -f "$tmp"
}

# ── issue preview ───────────────────────────────────────────────

issue_preview() {
    local line=$1 key repo num gh_repo
    # Extract <repo>#<num> from hidden tab field
    key=$(echo "$line" | sed -n 's/.*\t\([^[:space:]]*#[0-9]*\)$/\1/p')
    if [[ -z "$key" ]]; then
        # Fallback: parse from visible columns
        repo=$(echo "$line" | awk '{print $1}')
        num=$(echo "$line" | awk '{print $2}' | tr -d '#')
        key="${repo}#${num}"
    fi
    repo="${key%#*}"
    num="${key#*#}"
    gh_repo=$(issue_repos | grep "^${repo}:" | cut -d: -f2)

    echo "── Issue: ${gh_repo}#${num} ──"
    echo ""

    gh issue view "$num" --repo "$gh_repo" --json \
        title,body,labels,state,url,assignees,createdAt,updatedAt,closedAt,comments 2>/dev/null \
    | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(f\"Title:  {d['title']}\")
print(f\"State:  {d['state']}\")
print(f\"URL:    {d['url']}\")
ass = ', '.join(a['login'] for a in d.get('assignees',[])) or '—'
print(f\"Assignees: {ass}\")
lbls = ' '.join(l['name'] for l in d.get('labels',[])) or '—'
print(f\"Labels: {lbls}\")
print(f\"Created: {d.get('createdAt','—')[:10]}  Updated: {d.get('updatedAt','—')[:10]}  Closed: {(d.get('closedAt') or '—')[:10]}\")
print()
body = d.get('body','') or '(empty)'
print('── Body ──')
print(body[:2500])
comments = d.get('comments',[]) or []
if comments:
    print()
    print('── Recent comments ──')
    for cm in comments[-3:]:
        author = cm.get('author',{}).get('login','?')
        when = cm.get('createdAt','')[:10]
        body = (cm.get('body','') or '').replace('\n', ' ')[:400]
        print(f'  [{when}] {author}: {body}')
" 2>/dev/null

    echo ""
    echo "── Linked PRs ──"
    gh pr list --repo "$gh_repo" --state all --search "issue:$num" \
        --json number,title,state,reviewDecision,url,isDraft 2>/dev/null \
    | python3 -c "
import json, sys
prs = json.load(sys.stdin)
if not prs: print('(no linked PRs)')
for pr in prs:
    rd = pr.get('reviewDecision') or '—'
    draft = ' [DRAFT]' if pr.get('isDraft') else ''
    print(f\"  PR #{pr['number']}: {pr['title']} ({pr['state']}, review={rd}){draft}\")
    print(f\"  {pr['url']}\")
" 2>/dev/null

    echo ""
    echo "── Active Agent Sessions ──"
    local map_file2
    map_file2=$(_cached_session_map 2>/dev/null)
    if [[ -s "$map_file2" ]]; then
        python3 -c "
import json
m = json.load(open('$map_file2'))
sessions = m.get('$repo#$num', [])
if not sessions: print('(no active agent sessions)')
else:
    for s in sessions: print(f'  {s}')
" 2>/dev/null
    else
        echo "(no active agent sessions)"
    fi
}

# ── issue browser (interactive fzf) ─────────────────────────────

issue_browser() {
    local repo_filter="${1:-}" force_flag="${2:-}" view="${3:-all}"

    # --all: clear filter; --force: skip cache
    [[ "$repo_filter" == "--all" ]] && repo_filter=""
    if [[ "$repo_filter" == "--force" ]]; then force_flag="--force"; repo_filter=""; fi
    [[ "$force_flag" == "--all" ]] && { repo_filter=""; force_flag="--force"; }

    if [[ -z "$repo_filter" ]]; then
        repo_filter=$(detect_repo_from_cwd)
        if [[ -n "$repo_filter" ]]; then
            echo "Auto-detected repo: $repo_filter (add --all for all repos)" >&2
        else
            echo "No repo detected from CWD; showing all repos" >&2
        fi
    fi

    if ! command -v fzf &>/dev/null; then
        echo "fzf not found. Install with: apt install fzf" >&2
        issue_list "$view" "$repo_filter" "$force_flag"
        return
    fi
    if ! command -v tmq &>/dev/null; then
        echo "tmq not found (needed to dispatch issues)" >&2
        return 1
    fi

    # Fetch with spinner
    local cached="cached"
    if [[ -n "$repo_filter" ]]; then
        _cache_valid "$repo_filter" || cached="fetching"
    else
        cached="fetching"
    fi
    echo "[$view] issues (${repo_filter:-all repos}, $cached)..." >&2

    if [[ ! -t 0 ]]; then
        issue_list "$view" "$repo_filter" "$force_flag"
        return
    fi

    # Stash env for ctrl-r reload
    [[ -z "$repo_filter" ]] && export TMS_ISSUE_REPO="--all" || export TMS_ISSUE_REPO="$repo_filter"
    export TMS_ISSUE_FORCE="$force_flag"
    export TMS_ISSUE_VIEW="$view"

    local next_view case_view
    case "$view" in
        all) next_view="active" ;;
        active) next_view="yours" ;;
        yours) next_view="stale" ;;
        stale) next_view="all" ;;
    esac
    case "$next_view" in
        all) case_view="All" ;;
        active) case_view="Active (with live agents)" ;;
        yours) case_view="Yours (assigned to @$GH_USER)" ;;
        stale) case_view="Stale (open >14d, no activity)" ;;
    esac

    local fzf_header="[$case_view]  enter:dispatch  ctrl-o:browser  ctrl-p:full preview  ctrl-e:review PR  ctrl-v:cycle view  ctrl-r:refresh  ctrl-s:sessions  ?:help  esc:cancel"

    local issue_data
    issue_data=$(issue_list "$view" "$repo_filter" "$force_flag")

    # Build ctrl-v reload per view
    local reload_v="tms issues --raw $TMS_ISSUE_REPO --force --view $next_view"
    local header_v="[$next_view]  enter:dispatch  ctrl-o:browser  ctrl-p:full preview  ctrl-e:review PR  ctrl-v:cycle view  ctrl-r:refresh  ctrl-s:sessions  ?:help  esc:cancel"

    local selected
    stty -ixon 2>/dev/null
    selected=$(echo "$issue_data" | fzf \
        --header="$fzf_header" \
        --header-first \
        --ansi \
        --no-sort \
        --preview="tms --preview {}" \
        --preview-window='right:60%:wrap' \
        --bind="enter:accept" \
        --bind="ctrl-o:execute(gh issue view \$(echo {} | sed -n 's/.*\\t\\([^[:space:]]*#[0-9]*\\)\$/\\1/p' | cut -d# -f2) --repo bogocat/\$(echo {} | sed -n 's/.*\\t\\([^[:space:]]*#[0-9]*\\)\$/\\1/p' | cut -d# -f1) --web 2>/dev/null)" \
        --bind="ctrl-p:execute(tms --preview {} | less -R)" \
        --bind="ctrl-e:execute(key=\$(echo {} | sed -n 's/.*\\t\\([^[:space:]]*#[0-9]*\\)\$/\\1/p'); repo=\${key%#*}; iss=\${key#*#}; pr=\$(gh pr list --repo bogocat/\$repo --search \"issue:\$iss\" --json number --jq '.[0].number' 2>/dev/null); if [[ -n \"\$pr\" ]]; then tmq review \$repo \$pr; else echo \"No linked PR found for \$repo#\$iss\"; fi)" \
        --bind="ctrl-s:reload(tms sessions)+change-header(enter:attach  ctrl-x/d:kill  ctrl-r:rename  ctrl-k:clean  ctrl-i:issues  ?:help  esc:cancel)+change-preview(name=\"\$(echo {} | sed 's/.*\\t//')\"; tmux capture-pane -t \"\$name\" -p -S -40 2>/dev/null | sed 's/^/  /')" \
        --bind="ctrl-v:reload($reload_v)+change-header($header_v)" \
        --bind="ctrl-r:reload(tms issues --raw $TMS_ISSUE_REPO --force --view $view)+change-header(refreshing...  enter=dispatch  ctrl-o=browser  ctrl-s=back  ?=help  esc=cancel)" \
        --bind="?:execute(printf '%s\n\n' 'KEYBINDINGS' '-----------' 'enter      dispatch agent (via tmq)' 'ctrl-o     open issue in browser' 'ctrl-p     full preview' 'ctrl-e     code review linked PR' 'ctrl-v     cycle view (All/Active/Yours/Stale)' 'ctrl-r     force refresh (skip cache)' 'ctrl-s     switch to session browser' '?          this help' 'esc        cancel' '' 'VIEW MODES' '-----------' 'All      all open + recently closed (14d)' 'Active   issues with a live agent session' 'Yours    assigned to you' 'Stale    open >14d, no activity, no agent' '' 'COLUMNS' '--------' 'ST  status (○open ●active ▶pr ◐draft ◎review ✎changes ✓ready ✗blocked ✔reviewed ?question)' 'AGE since created  UPD since last update  ★ assigned to you' | less -R)" \
        2>/dev/null || true)

    if [[ -n "$selected" ]]; then
        local key repo num
        key=$(echo "$selected" | sed -n 's/.*\t\([^[:space:]]*#[0-9]*\)$/\1/p')
        if [[ -n "$key" ]]; then
            repo="${key%#*}"
            num="${key#*#}"
            tmq "$repo" "$num"
            exec tms
        fi
    fi
}

# ═══════════════════════════════════════════════════════════════
# Session browser (formerly the default behavior of `tms`)
# ═══════════════════════════════════════════════════════════════

session_age_seconds() {
    local created
    created=$(tmux display-message -t "$1" -p '#{session_created}' 2>/dev/null) || echo 0
    echo $((NOW - created))
}

session_age_human() {
    local secs=$1
    if   (( secs < 3600 ));       then echo "$((secs / 60))m ago"
    elif (( secs < 86400 ));      then echo "$((secs / 3600))h ago"
    elif (( secs < 604800 ));     then echo "$((secs / 86400))d ago"
    else                               echo "$((secs / 604800))w ago"
    fi
}

detect_agent() {
    local cmd=$1
    case "$cmd" in
        pi)       echo "π" ;;
        claude)   echo "cc" ;;
        opencode) echo "oc" ;;
        python3)  echo "py" ;;
        bash)     echo "sh" ;;
        zsh)      echo "sh" ;;
        *)        echo "${cmd:0:3}" ;;
    esac
}

is_session_stale() {
    local name=$1
    local age_sec attached
    age_sec=$(session_age_seconds "$name")
    (( age_sec <= STALE_DAYS * 86400 )) && return 1
    attached=$(tmux list-sessions -F "#{session_attached}" -f "#{==:#{session_name},$name}" 2>/dev/null)
    (( attached > 0 )) && return 1
    local panes
    panes=$(tmux list-panes -t "$name" -F "#{pane_current_command}" 2>/dev/null) || return 1
    while IFS= read -r cmd; do
        [[ -z "$cmd" ]] && continue
        case "$cmd" in
            bash|zsh|fish|sh|dash) ;;
            *) return 1 ;;
        esac
    done <<< "$panes"
    return 0
}

# Read cached NDJSON issue files and produce "repo#num → sym|status|color"
_session_status_lookup() {
    local cache_dir="$ISSUE_CACHE_DIR"
    [[ -d "$cache_dir" ]] || { echo ""; return; }
    python3 - "$cache_dir" << 'PYEOF'
import json, sys, os, glob
R='\033[31m'; G='\033[32m'; Y='\033[33m'; M='\033[35m'; C='\033[36m'; D='\033[2m'; N='\033[0m'
cache_dir = sys.argv[1]
for f in sorted(glob.glob(os.path.join(cache_dir, '*.ndjson'))):
    try:
        with open(f) as fh:
            for line in fh:
                line = line.strip()
                if not line: continue
                try: iss = json.loads(line)
                except Exception: continue
                # We don't have full enrichment here, just labels. Best-effort.
                key = f"{iss.get('repo','')}#{iss.get('n') or iss.get('number','')}"
                if not iss.get('repo'): continue
                labels = (iss.get('l') or iss.get('labels','') or '').lower()
                state = iss.get('s') or iss.get('state','')
                if 'blocked' in labels: print(f"{key}\t✗\tblocked\t31")
                elif 'question' in labels: print(f"{key}\t?\tquestion\t35")
                elif 'reviewed' in labels: print(f"{key}\t✔\treviewed\t32")
                elif state == 'CLOSED': print(f"{key}\t✕\tclosed\t2")
                else: print(f"{key}\t○\topen\t2")
    except Exception: continue
PYEOF
}

compact_session_name() {
    local name=$1
    if [[ "$name" =~ ^(feat|fix|chore|review)- ]]; then echo "$name"; return; fi
    if [[ "$name" == aoe_* ]]; then
        local stripped="${name#aoe_}"
        local uuid="${stripped##*_}"
        if [[ "$uuid" =~ ^[0-9a-f]{6,}$ ]]; then
            stripped="${stripped%_$uuid}"
        fi
        if [[ "$stripped" =~ _([0-9]+)$ ]]; then
            stripped="${stripped%_${BASH_REMATCH[1]}}#${BASH_REMATCH[1]}"
        fi
        echo "$stripped"; return
    fi
    echo "$name"
}

session_info() {
    local name=$1 status_map="${2:-}" session_issue="${3:-}"
    local cmd cwd attached wins age_sec
    cmd=$(tmux list-panes -t "$name" -F "#{pane_current_command}" 2>/dev/null | head -1)
    cwd=$(tmux list-panes -t "$name" -F "#{pane_current_path}" 2>/dev/null | head -1)
    attached=$(tmux list-sessions -F "#{session_attached}" -f "#{==:#{session_name},$name}" 2>/dev/null)
    wins=$(tmux list-sessions -F "#{session_windows}" -f "#{==:#{session_name},$name}" 2>/dev/null)
    age_sec=$(session_age_seconds "$name")

    local short_cwd="$cwd"
    short_cwd="${short_cwd/#\/root/}"
    short_cwd="${short_cwd/#\/home/}"
    [[ -z "$short_cwd" ]] && short_cwd="/"
    short_cwd="${short_cwd#/}"

    local agent_icon
    agent_icon=$(detect_agent "$cmd")

    local att_marker=" "
    (( attached > 0 )) && att_marker="*"

    local age_str
    age_str=$(session_age_human "$age_sec")

    local stale_flag=" "
    is_session_stale "$name" && stale_flag="⚰"

    local win_mark="$wins"
    (( wins > 1 )) && win_mark="${wins}w"

    local disp_name
    disp_name=$(compact_session_name "$name")
    if (( ${#disp_name} > 28 )); then disp_name="${disp_name:0:25}…"; fi

    local issue="—"
    local issue_key=""
    if [[ "$name" =~ ^(feat|fix|chore|review)-(.+)#([0-9]+) ]]; then
        issue_key="${BASH_REMATCH[2]}#${BASH_REMATCH[3]}"
    fi
    [[ -z "$issue_key" && -n "$session_issue" ]] && issue_key="$session_issue"

    if [[ -n "$issue_key" && -n "$status_map" && -f "$status_map" ]]; then
        local lookup
        lookup=$(grep "^${issue_key}"$'\t' "$status_map" 2>/dev/null | head -1 || true)
        if [[ -n "$lookup" ]]; then
            local sym color_code ec nc
            sym=$(echo "$lookup" | cut -f2)
            color_code=$(echo "$lookup" | cut -f4)
            [[ "$color_code" == "0" ]] && color_code="36;1"
            printf -v ec '\033[%sm' "$color_code"
            printf -v nc '\033[0m'
            issue="${ec}${sym} ${issue_key}${nc}"
        else
            issue="${issue_key}"
        fi
    fi

    printf "%-28s %s%-1s %-3s %-7s %-3s %-24s %s\t%s\n" \
        "$disp_name" "$att_marker" "$agent_icon" "$win_mark" "$age_str" "$stale_flag" "$issue" "$short_cwd" "$name"
}

session_list_text() {
    local status_map
    status_map=$(mktemp /tmp/tms-session-status-XXXXXX.tsv)
    _session_status_lookup > "$status_map" 2>/dev/null || true

    local sess_map
    sess_map=$(_cached_session_map 2>/dev/null || echo "")
    local aoe_issues
    aoe_issues=$(mktemp /tmp/tms-aoe-issues-XXXXXX.tsv)
    if [[ -n "$sess_map" && -s "$sess_map" ]]; then
        python3 -c "
import json
m = json.load(open('$sess_map'))
for key, sessions in m.items():
    for s in sessions:
        name = s.split(' ')[0]
        print(f'{name}\t{key}')
" > "$aoe_issues" 2>/dev/null || true
    fi

    printf "%-28s %-4s %-3s %-7s %-3s %-24s %s\n" "SESSION" " " "AG" "#W" "AGE" "ISSUE" "CWD"
    printf "%s\n" "──────────────────────────────────────────────────────────────────────"

    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | sort)
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        local sess_issue=""
        if [[ -s "$aoe_issues" ]]; then
            sess_issue=$(grep "^${name}"$'\t' "$aoe_issues" 2>/dev/null | head -1 | cut -f2 || true)
        fi
        session_info "$name" "$status_map" "$sess_issue"
    done <<< "$sessions"

    rm -f "$status_map" "$aoe_issues"
}

attach_session() {
    local name=$1
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$name"
    else
        tmux attach-session -t "$name"
    fi
}

kill_session() {
    local name=$1 force="${2:-}"
    if [[ "$force" == "--force" ]]; then
        tmux kill-session -t "$name" 2>/dev/null && echo "Killed $name." || echo "Failed to kill $name."
        return
    fi
    printf "Kill session '%s'? [y/N] " "$name"
    read -r ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
        tmux kill-session -t "$name" 2>/dev/null && echo "Killed." || echo "Failed."
    fi
}

rename_session() {
    local name=$1
    printf "New name for '%s': " "$name"
    read -r newname
    if [[ -n "$newname" ]]; then
        tmux rename-session -t "$name" "$newname" 2>/dev/null && echo "Renamed to $newname." || echo "Failed."
    fi
}

stale_sessions() {
    printf "%-20s %-7s %-4s %s\n" "SESSION" "AGE" "WINS" "WINDOWS"
    printf "%s\n" "──────────────────────────────────────────────────"
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if is_session_stale "$name"; then
            local age_sec wins cwd
            age_sec=$(session_age_seconds "$name")
            wins=$(tmux list-sessions -F "#{session_windows}" -f "#{==:#{session_name},$name}" 2>/dev/null)
            cwd=$(tmux list-panes -t "$name" -F "#{pane_current_path}" 2>/dev/null | head -1)
            local win_detail
            win_detail=$(tmux list-windows -t "$name" -F "#{window_index}:#{pane_current_command}" 2>/dev/null | tr '\n' ' ')
            printf "%-20s %-7s %-4s %s  (%s)\n" \
                "$name" "$(session_age_human "$age_sec")" "$wins" "$cwd" "$win_detail"
        fi
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null | sort)"
}

compact_scratch_sessions() {
    local prefixes=()
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        if [[ "$name" =~ ^([a-z])([0-9]+)$ ]]; then
            local p="${BASH_REMATCH[1]}"
            [[ " ${prefixes[*]:-} " != *" $p "* ]] && prefixes+=("$p")
        fi
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null)"

    for prefix in "${prefixes[@]}"; do
        local -a remaining=()
        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            if [[ "$name" =~ ^${prefix}[0-9]+$ ]]; then
                remaining+=("$name")
            fi
        done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^${prefix}[0-9]\+$" | sort -V)"

        local idx=0 renamed=0
        for s in "${remaining[@]}"; do
            local target="${prefix}${idx}"
            if [[ "$s" != "$target" ]]; then
                local att
                att=$(tmux list-sessions -F "#{session_attached}" -f "#{==:#{session_name},$s}" 2>/dev/null)
                if (( att > 0 )); then
                    echo "  skip $s → $target (attached)"
                else
                    tmux rename-session -t "$s" "$target" 2>/dev/null && \
                        echo "  $s → $target" && renamed=1
                fi
            fi
            ((idx++))
        done
        (( renamed )) && echo "  (${prefix}* compacted)" || true
    done
}

clean_stale() {
    local -a to_kill=()
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        is_session_stale "$name" && to_kill+=("$name")
    done <<< "$(tmux list-sessions -F "#{session_name}" 2>/dev/null | sort)"

    if ((${#to_kill[@]} == 0)); then
        echo "No stale sessions found (>${STALE_DAYS}d, all windows idle)."
        return
    fi
    echo "Stale sessions (>${STALE_DAYS}d):"
    for s in "${to_kill[@]}"; do
        local wins
        wins=$(tmux list-sessions -F "#{session_windows}" -f "#{==:#{session_name},$s}" 2>/dev/null)
        local win_detail
        win_detail=$(tmux list-windows -t "$s" -F "#{window_index}:#{pane_current_command}" 2>/dev/null | tr '\n' ' ')
        echo "  $s  (${wins} windows: $win_detail)"
    done
    local auto_yes="${2:-}"
    if [[ "$auto_yes" != "--yes" ]]; then
        printf "Kill all %d? [y/N] " "${#to_kill[@]}"
        read -r ans
        [[ ! "$ans" =~ ^[Yy]$ ]] && { echo "Cancelled."; return; }
    fi
    for s in "${to_kill[@]}"; do
        tmux kill-session -t "$s" 2>/dev/null && echo "  killed $s" || echo "  failed $s"
    done
    if [[ "$auto_yes" != "--yes" ]]; then
        printf "Compact scratch session numbers? [Y/n] "
        read -r ans2
        [[ "$ans2" =~ ^[Nn]$ ]] && return
    fi
    compact_scratch_sessions
}

session_browser() {
    if ! command -v fzf &>/dev/null; then
        echo "fzf not found. Install with: apt install fzf" >&2
        session_list_text
        return
    fi
    stty -ixon 2>/dev/null
    local selected
    selected=$(session_list_text | fzf \
        --header='enter:attach  ctrl-x/d:kill  ctrl-r:rename  ctrl-k:clean  ctrl-p:peek  ctrl-i:issues  ?:help  esc:cancel' \
        --header-first --ansi --no-sort \
        --preview='name=$(echo {} | sed "s/.*\t//"); tmux capture-pane -t "$name" -p -S -40 2>/dev/null | sed "s/^/  /"' \
        --preview-window='right:60%:wrap' \
        --bind="enter:accept" \
        --bind="ctrl-x:execute(real=\$(echo {} | sed 's/.*\t//'); tms kill \$real --force)+reload(tms ls | tail -n +3)" \
        --bind="ctrl-d:execute(real=\$(echo {} | sed 's/.*\t//'); tms kill \$real --force)+reload(tms ls | tail -n +3)" \
        --bind="ctrl-r:become(stty sane; real=\$(echo {} | sed 's/.*\t//'); tms rename \$real; exec tms)" \
        --bind="ctrl-p:execute(real=\$(echo {} | sed 's/.*\t//'); tmux capture-pane -t \"\$real\" -p -S -40 | less -R)" \
        --bind="ctrl-k:execute(tms clean --yes)+reload(tms ls | tail -n +3)" \
        --bind="ctrl-i:reload(tms issues --raw --all)+change-header(issues: enter=dispatch  ctrl-o=browser  ctrl-p=preview  ctrl-v=view  ctrl-s=back  ?=help  esc=cancel)+change-preview(tms --preview {})" \
        --bind="ctrl-s:reload(tms ls | tail -n +3)+change-header(enter:attach  ctrl-x/d:kill  ctrl-r:rename  ctrl-k:clean  ctrl-p:peek  ctrl-i:issues  ?:help  esc:cancel)+change-preview(name=\"\$(echo {} | sed 's/.*\\t//')\"; tmux capture-pane -t \"\$name\" -p -S -40 2>/dev/null | sed 's/^/  /')" \
        --bind="?:execute(printf '%s\n\n' 'KEYBINDINGS' '-----------' 'enter      attach' 'ctrl-x/d   kill session' 'ctrl-r     rename' 'ctrl-k     clean stale' 'ctrl-i     switch to issues' 'ctrl-s     back to sessions' 'ctrl-p     peek terminal' '?          help' 'esc        cancel' | less -R)" \
        --tac) || true

    if [[ -n "$selected" ]]; then
        local col1 col2 real_name
        col1=$(echo "$selected" | awk '{print $1}')
        col2=$(echo "$selected" | awk '{print $2}' | tr -d '#')
        real_name=$(echo "$selected" | sed 's/.*\t//')
        if echo "$col1" | grep -qE '^(distillery|home-portal|tower-fleet|scripts|palimpsest|rms)$'; then
            tmq "$col1" "$col2"
            exec tms
        else
            attach_session "$real_name"
            [[ -z "${TMUX:-}" ]] && exec tms
        fi
    fi
}

# ── main ────────────────────────────────────────────────────────

case "${1:-}" in
    ls|list)
        session_list_text
        ;;
    kill)
        [[ -z "${2:-}" ]] && { echo "Usage: tms kill <name>"; exit 1; }
        kill_session "$2" "${3:-}"
        ;;
    rename)
        [[ -z "${2:-}" ]] && { echo "Usage: tms rename <name>"; exit 1; }
        rename_session "$2"
        ;;
    stale) stale_sessions ;;
    clean) clean_stale "$@" ;;
    compact) compact_scratch_sessions ;;
    sessions|session)
        shift
        session_browser
        ;;
    issues)
        shift
        # Parse --view / --raw / --force / --all / --clear-cache
        view="all"; raw=""; force=""; repo_arg=""; clear=""
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --view) view="$2"; shift 2 ;;
                --raw) raw="--raw"; shift ;;
                --force) force="--force"; shift ;;
                --all) repo_arg="--all"; shift ;;
                --clear-cache) clear=1; shift ;;
                *) [[ -z "$repo_arg" ]] && repo_arg="$1"; shift ;;
            esac
        done
        if [[ -n "$clear" ]]; then _clear_cache; echo "Issue cache cleared."; exit 0; fi
        if [[ "$repo_arg" == "--all" ]]; then repo_arg=""; fi
        if [[ -z "$repo_arg" && -z "${TMS_NO_AUTO:-}" ]]; then
            detected=$(detect_repo_from_cwd)
            if [[ -n "$detected" ]]; then
                repo_arg="$detected"
            fi
        fi
        if [[ -n "$raw" ]]; then
            issue_list "$view" "$repo_arg" "$force"
            exit 0
        fi
        issue_browser "$repo_arg" "$force" "$view"
        ;;
    "")
        # DEFAULT: issue browser
        issue_browser
        ;;
    --all)
        TMS_NO_AUTO=1 issue_browser --all
        ;;
    --raw|--raw=*)
        # Convenience: tms --raw [--all | repo] [--view X]
        shift
        TMS_NO_AUTO=1
        repo_arg=""
        force_flag=""
        view="all"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --all) repo_arg="--all"; shift ;;
                --view) view="$2"; shift 2 ;;
                --force) force_flag="--force"; shift ;;
                *) [[ -z "$repo_arg" ]] && repo_arg="$1"; shift ;;
            esac
        done
        if [[ -z "$repo_arg" ]]; then
            detected=$(detect_repo_from_cwd)
            [[ -n "$detected" ]] && repo_arg="$detected"
        fi
        [[ "$repo_arg" == "--all" ]] && repo_arg=""
        issue_list "$view" "$repo_arg" "$force_flag"
        ;;
    --preview)
        issue_preview "${2:-}"
        ;;
    -h|--help)
        sed -n '2,30p' "$0"
        ;;
    *)
        echo "Usage: tms [sessions|issues|ls|kill|rename|stale|clean|compact]"
        exit 1
        ;;
esac
